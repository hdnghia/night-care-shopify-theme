{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_mobile | default: blockMarginTop_responsive_range_desktop }}px;
    --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_mobile | default: blockMarginBottom_responsive_range_desktop }}px;
    --{{ block.id }}--productPricePriceTextAlign_text_alignment: {{ productPricePriceTextAlign_text_alignment_mobile | default: productPricePriceTextAlign_text_alignment_desktop }};
    --{{ block.id }}--productPriceCompareAtPriceTextAlign_text_alignment: {{ productPriceCompareAtPriceTextAlign_text_alignment_mobile | default: productPriceCompareAtPriceTextAlign_text_alignment_desktop }};
    --{{ block.id }}--productDiscountTagIconIconSize_responsive_range: {{ productDiscountTagIconIconSize_responsive_range_mobile | default: productDiscountTagIconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--productDiscountTagTextTextAlign_text_alignment: {{ productDiscountTagTextTextAlign_text_alignment_mobile | default: productDiscountTagTextTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_desktop }}px;
      --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_desktop }}px;
      --{{ block.id }}--productPricePriceTextAlign_text_alignment: {{ productPricePriceTextAlign_text_alignment_desktop }};
      --{{ block.id }}--productPriceCompareAtPriceTextAlign_text_alignment: {{ productPriceCompareAtPriceTextAlign_text_alignment_desktop }};
      --{{ block.id }}--productDiscountTagIconIconSize_responsive_range: {{ productDiscountTagIconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--productDiscountTagTextTextAlign_text_alignment: {{ productDiscountTagTextTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div
  {{ block.shopify_attributes }}
  class="relative transition-all duration-150 ease-in-out flex flex-row items-center gap-3 "
  style="margin-top: var(--{{ block.id }}--blockMarginTop_responsive_range); margin-bottom: var(--{{ block.id }}--blockMarginBottom_responsive_range);">
  <div class="flex flex-row gap-1.5  items-center transition-all duration-150 ease-in-out [&_[data-dm-element='product-price']]:text-destructive [&_[data-dm-element='product-compare-at-price']]:text-foreground" id="price-{{ section.id }}">
    {%- assign target = product.has_only_default_variant | default: false | boolean -%}
    {%- if target -%}
      {%- assign variantData = product -%}
    {%- else -%}
      {%- assign variantData = product.selected_or_first_available_variant -%}
    {%- endif -%}

    <p
      data-dm-element="product-price"
      class="text-foreground {{ productPricePriceTextStyle_font_mobile }} sm:{{ productPricePriceTextStyle_font_desktop }} dropmagic-text"
      style="text-align: var(--{{ block.id }}--productPricePriceTextAlign_text_alignment); color: {{ productPricePriceTextColor_color }};">{{ variantData.price | money }}</p>
    {% if variantData.compare_at_price %}
      <p
        data-dm-element="product-compare-at-price"
        class="text-foreground line-through opacity-50 decoration-inherit {{ productPriceCompareAtPriceTextStyle_font_mobile }} sm:{{ productPriceCompareAtPriceTextStyle_font_desktop }} dropmagic-text"
        style="text-align: var(--{{ block.id }}--productPriceCompareAtPriceTextAlign_text_alignment); color: {{ productPriceCompareAtPriceTextColor_color }};">{{ variantData.compare_at_price | money }}</p>
  {% else %}
    {% endif %}
  </div>
  {% if productDiscountTagHideBadge_checkbox == false %}
    <div class="py-1 w-fit flex flew-row items-center  shadow-sm px-1.5 gap-1 rounded-xs bg-destructive [&>p]:text-destructive-foreground" style="background-color: {{ productDiscountTagTagBackground_color }}; border-color: {{ productDiscountTagTagBorder_color }}; border-style: solid; border-radius: {{ productDiscountTagTagRadius_number }}px; border-width: {{ productDiscountTagTagBorder_number }}px;">
      {% if productDiscountTagIcon_icon %}
        {% unless productDiscountTagIcon_icon == blank %}
          {% assign icon_text = productDiscountTagIcon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-inherit"
              style="aspect-ratio: 1/1; color: {{ productDiscountTagIconIconColor_color }}; width: var(--{{ block.id }}--productDiscountTagIconIconSize_responsive_range); height: var(--{{ block.id }}--productDiscountTagIconIconSize_responsive_range);">{{ productDiscountTagIcon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-inherit"
              style="line-height: 100%; font-size: var(--{{ block.id }}--productDiscountTagIconIconSize_responsive_range);">{{ productDiscountTagIcon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}
      <p class="line-clamp-2 w-full overflow-hidden text-inherit {{ productDiscountTagTextTextStyle_font_mobile }} sm:{{ productDiscountTagTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--productDiscountTagTextTextAlign_text_alignment); color: {{ productDiscountTagTextTextColor_color }};">{{ productDiscountTagText_text }}</p>
    </div>
{% else %}
  {% endif %}
</div>