{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--imageHeight_responsive_range: {{ imageHeight_responsive_range_mobile | default: imageHeight_responsive_range_desktop }}px;
    --{{ block.id }}--imageImageAspectRatio_responsive_select: {{ imageImageAspectRatio_responsive_select_mobile | default: imageImageAspectRatio_responsive_select_desktop }};
    --{{ block.id }}--cardTitleTextAlign_text_alignment: {{ cardTitleTextAlign_text_alignment_mobile | default: cardTitleTextAlign_text_alignment_desktop }};
    --{{ block.id }}--cardDescriptionTextAlign_text_alignment: {{ cardDescriptionTextAlign_text_alignment_mobile | default: cardDescriptionTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--imageHeight_responsive_range: {{ imageHeight_responsive_range_desktop }}px;
      --{{ block.id }}--imageImageAspectRatio_responsive_select: {{ imageImageAspectRatio_responsive_select_desktop }};
      --{{ block.id }}--cardTitleTextAlign_text_alignment: {{ cardTitleTextAlign_text_alignment_desktop }};
      --{{ block.id }}--cardDescriptionTextAlign_text_alignment: {{ cardDescriptionTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div {{ block.shopify_attributes }} class="relative transition-all duration-150 ease-in-out flex-1 snap-center ">


  {% assign card_style_value = settings.card_style %}
  {% if cardStyle_select != blank %}
    {% assign card_style_value = cardStyle_select %}
  {% endif %}


  {%- capture card_classes -%}
    {% render 'dm_classname_utils'
     , type: "card",
     card_variant: card_style_value,
     card_size: cardSize_select %}
  {%- endcapture -%}


  <div class="overflow-hidden rounded-md border-solid  transition-all duration-150 ease-in-out bg-card border-border relative h-full flex flex-col min-w-[85vw] md:min-w-[initial] {{ card_classes | strip }}" style="background-color: {{ cardBackground_color }}; border-color: {{ cardBorder_color }}; border-width: {{ cardBorderWidth_number }}px; border-radius: {{ cardRadius_range }}px;">
    <div class="relative w-full" style="height: inherit;">

      {% unless imageImageHide_responsive_checkbox_mobile and imageImageHide_responsive_checkbox_desktop %}

        {% assign media_style_value = settings.media_style %}
        {% if imageImageStyle_select != blank %}
          {% assign media_style_value = imageImageStyle_select %}
        {% endif %}
        {% if imageImageMask_media_mask != blank %}
          {% assign media_style_value = "none" %}
        {% endif %}


        {%- capture media_classes -%}
          {% render 'dm_classname_utils'
           , type: "media",
           media_style: media_style_value %}
        {%- endcapture -%}

        {% if imageImageMask_media_mask != blank %}
          {% assign id_part = imageImageMask_media_mask | split: 'id="' | last | split: '"' | first %}
          <svg
            width="0"
            height="0"
            style="position: absolute;">
            <defs>{{ imageImageMask_media_mask }}</defs>
          </svg>
        {% endif %}

        {% liquid
    if imageHeight_responsive_range_mobile != blank
      assign mobile_width = 'w-auto'
    else
      assign mobile_width = 'w-full'
    endif

    if imageHeight_responsive_range_desktop != blank
      assign desktop_width = 'sm:w-auto'
    else
      assign desktop_width = 'sm:w-full'
    endif

    assign width_classes = mobile_width | append: ' ' | append: desktop_width
  %}

        {% if image_media != blank or image_media_video != blank %}
          <div class="relative max-w-full [&>img]:!rounded-b-none [&>video]:!rounded-b-none {% if imageImageHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif imageImageHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}" style="aspect-ratio: var(--{{ block.id }}--imageImageAspectRatio_responsive_select); height: var(--{{ block.id }}--imageHeight_responsive_range);">

            {% assign video_extensions = '.mp4,.webm,.mov,.avi,.avif,.m4v' | split: ',' %}
            {% assign is_valid_video = false %}
            {% for ext in video_extensions %}
              {% if image_media_video contains ext %}
                {% assign is_valid_video = true %}
                {% break %}
              {% endif %}
            {% endfor %}

            {% if image_media_video != blank and is_valid_video %}
              {% assign video_url = image_media_video | split: '?' | first %}
              {% assign video_params = image_media_video | split: '?' | last | split: '&' %}
              {% assign video_attrs = '' %}
              {% for param in video_params %}
                {% assign key_value = param | split: '=' %}
                {% assign key = key_value | first | downcase %}
                {% assign value = key_value | last %}
                {% case key %}
                  {% when 'loop' %}
                  {% assign video_attrs = video_attrs | append: ' loop' %}
                  {% when 'autoplay' %}
                  {% assign video_attrs = video_attrs | append: ' autoplay' %}
                  {% when 'muted' %}
                  {% assign video_attrs = video_attrs | append: ' muted' %}
                  {% when 'controls' %}
                  {% assign video_attrs = video_attrs | append: ' controls' %}
                  {% when 'playsinline' %}
                  {% assign video_attrs = video_attrs | append: ' playsinline' %}
                {% endcase %}
              {% endfor %}
              <video
                src="{{ video_url }}"
                {% if image_media != blank %}poster="{{ image_media | image_url }}"{% endif %}
                alt=" "
                preload="metadata"
                draggable="false"
                class="border-solid h-full object-cover {{ media_classes | strip }} {{ width_classes }}"
                style="{% if id_part != blank %}clip-path: url(#{{id_part}}); -webkit-clip-path: url(#{{id_part}});{% endif %} {% if imageImageBorder_number != blank %} border-width: {{ imageImageBorder_number }}px;{% endif %} {% if imageImageBorder_color != blank %} border-color:{{ imageImageBorder_color }};{% endif %} {% if imageImageRadius_number != blank %} border-radius: {{ imageImageRadius_number }}px;{% endif %} {% if imageImagePosition_select != blank %} object-position: {{ imageImagePosition_select }};{% endif %}"
                {{ video_attrs }}></video>
            {% else %}
              <img
                src="{{ image_media | image_url }}"
                alt=" "
                draggable="false"
                loading="lazy"
                class="border-solid h-full object-cover {{ media_classes | strip }} {{ width_classes }}"
                style="{% if id_part != blank %}clip-path: url(#{{id_part}}); -webkit-clip-path: url(#{{id_part}});{% endif %} {% if imageImageBorder_number != blank %} border-width: {{ imageImageBorder_number }}px;{% endif %} {% if imageImageBorder_color != blank %} border-color:{{ imageImageBorder_color }};{% endif %} {% if imageImageRadius_number != blank %} border-radius: {{ imageImageRadius_number }}px;{% endif %} {% if imageImagePosition_select != blank %} object-position: {{ imageImagePosition_select }};{% endif %}">
            {% endif %}
          </div>
        {% else %}
          <div class="relative max-w-full [&>img]:!rounded-b-none [&>video]:!rounded-b-none {{ media_align_class }} {% if imageImageHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif imageImageHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}" style="aspect-ratio: var(--{{ block.id }}--imageImageAspectRatio_responsive_select);">
            {{ 'image' | placeholder_svg_tag: width_classes | strip }}
          </div>
        {% endif %}
      {% endunless %}

    </div>
    <div class="flex flex-col px-4 py-4 gap-2 flex-grow h-full">
      <h3 class="text-card-foreground {{ cardTitleTextStyle_font_mobile }} sm:{{ cardTitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--cardTitleTextAlign_text_alignment); color: {{ cardTitleTextColor_color }};">{{ cardTitle_text }}</h3>
      <p class="text-card-foreground {{ cardDescriptionTextStyle_font_mobile }} sm:{{ cardDescriptionTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--cardDescriptionTextAlign_text_alignment); color: {{ cardDescriptionTextColor_color }};">{{ cardDescription_text }}</p>
    </div>
  </div>
</div>