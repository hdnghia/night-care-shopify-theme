{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_mobile | default: blockMarginTop_responsive_range_desktop }}px;
    --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_mobile | default: blockMarginBottom_responsive_range_desktop }}px;
    --{{ block.id }}--boxValueProp1IconIconSize_responsive_range: {{ boxValueProp1IconIconSize_responsive_range_mobile | default: boxValueProp1IconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--boxValueProp1TitleTextAlign_text_alignment: {{ boxValueProp1TitleTextAlign_text_alignment_mobile | default: boxValueProp1TitleTextAlign_text_alignment_desktop }};
    --{{ block.id }}--boxValueProp1ContentTextAlign_text_alignment: {{ boxValueProp1ContentTextAlign_text_alignment_mobile | default: boxValueProp1ContentTextAlign_text_alignment_desktop }};
    --{{ block.id }}--boxValueProp2IconIconSize_responsive_range: {{ boxValueProp2IconIconSize_responsive_range_mobile | default: boxValueProp2IconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--boxValueProp2TitleTextAlign_text_alignment: {{ boxValueProp2TitleTextAlign_text_alignment_mobile | default: boxValueProp2TitleTextAlign_text_alignment_desktop }};
    --{{ block.id }}--boxValueProp2ContentTextAlign_text_alignment: {{ boxValueProp2ContentTextAlign_text_alignment_mobile | default: boxValueProp2ContentTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_desktop }}px;
      --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_desktop }}px;
      --{{ block.id }}--boxValueProp1IconIconSize_responsive_range: {{ boxValueProp1IconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--boxValueProp1TitleTextAlign_text_alignment: {{ boxValueProp1TitleTextAlign_text_alignment_desktop }};
      --{{ block.id }}--boxValueProp1ContentTextAlign_text_alignment: {{ boxValueProp1ContentTextAlign_text_alignment_desktop }};
      --{{ block.id }}--boxValueProp2IconIconSize_responsive_range: {{ boxValueProp2IconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--boxValueProp2TitleTextAlign_text_alignment: {{ boxValueProp2TitleTextAlign_text_alignment_desktop }};
      --{{ block.id }}--boxValueProp2ContentTextAlign_text_alignment: {{ boxValueProp2ContentTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div
  {{ block.shopify_attributes }}
  class="relative transition-all duration-150 ease-in-out "
  style="margin-top: var(--{{ block.id }}--blockMarginTop_responsive_range); margin-bottom: var(--{{ block.id }}--blockMarginBottom_responsive_range);">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-2 ">
    <div class="px-3 py-3 rounded-sm flex  bg-card border-border shadow-xs {% if boxValueProp1BoxAlign_select == "column" %}flex-col items-center gap-y-2{% else %}flex-row items-start gap-x-3{% endif %}" style="background-color: {{ boxValueProp1BoxBackground_color }}; border-color: {{ boxValueProp1BoxBorder_color }}; border-style: solid; border-radius: {{ boxValueProp1BoxRadius_number }}px; border-width: {{ boxValueProp1BoxBorder_number }}px;">
      {% if boxValueProp1Icon_icon %}
        {% unless boxValueProp1Icon_icon == blank %}
          {% assign icon_text = boxValueProp1Icon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-accent"
              style="aspect-ratio: 1/1; color: {{ boxValueProp1IconIconColor_color }}; width: var(--{{ block.id }}--boxValueProp1IconIconSize_responsive_range); height: var(--{{ block.id }}--boxValueProp1IconIconSize_responsive_range);">{{ boxValueProp1Icon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-accent"
              style="line-height: 100%; font-size: var(--{{ block.id }}--boxValueProp1IconIconSize_responsive_range);">{{ boxValueProp1Icon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}

      <div class="flex flex-col gap-y-[1px]">
        <h3 class="text-foreground {{ boxValueProp1TitleTextStyle_font_mobile }} sm:{{ boxValueProp1TitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--boxValueProp1TitleTextAlign_text_alignment); color: {{ boxValueProp1TitleTextColor_color }};">{{ boxValueProp1Title_text }}</h3>
        <p class="text-muted-foreground {{ boxValueProp1ContentTextStyle_font_mobile }} sm:{{ boxValueProp1ContentTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--boxValueProp1ContentTextAlign_text_alignment); color: {{ boxValueProp1ContentTextColor_color }};">{{ boxValueProp1Content_text }}</p>
      </div>
    </div>
    <div class="px-3 py-3 rounded-sm flex  bg-card border-border shadow-xs {% if boxValueProp2BoxAlign_select == "column" %}flex-col items-center gap-y-2{% else %}flex-row items-start gap-x-3{% endif %}" style="background-color: {{ boxValueProp2BoxBackground_color }}; border-color: {{ boxValueProp2BoxBorder_color }}; border-style: solid; border-radius: {{ boxValueProp2BoxRadius_number }}px; border-width: {{ boxValueProp2BoxBorder_number }}px;">
      {% if boxValueProp2Icon_icon %}
        {% unless boxValueProp2Icon_icon == blank %}
          {% assign icon_text = boxValueProp2Icon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-accent"
              style="aspect-ratio: 1/1; color: {{ boxValueProp2IconIconColor_color }}; width: var(--{{ block.id }}--boxValueProp2IconIconSize_responsive_range); height: var(--{{ block.id }}--boxValueProp2IconIconSize_responsive_range);">{{ boxValueProp2Icon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-accent"
              style="line-height: 100%; font-size: var(--{{ block.id }}--boxValueProp2IconIconSize_responsive_range);">{{ boxValueProp2Icon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}

      <div class="flex flex-col gap-y-[1px]">
        <h3 class="text-foreground {{ boxValueProp2TitleTextStyle_font_mobile }} sm:{{ boxValueProp2TitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--boxValueProp2TitleTextAlign_text_alignment); color: {{ boxValueProp2TitleTextColor_color }};">{{ boxValueProp2Title_text }}</h3>
        <p class="text-muted-foreground {{ boxValueProp2ContentTextStyle_font_mobile }} sm:{{ boxValueProp2ContentTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--boxValueProp2ContentTextAlign_text_alignment); color: {{ boxValueProp2ContentTextColor_color }};">{{ boxValueProp2Content_text }}</p>
      </div>
    </div>
  </div>
</div>