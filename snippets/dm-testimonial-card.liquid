{% comment %}
  Testimonial card — used by dm-testimonials section.
  @param title @param review @param customer_name @param location
  @param avatar {image} optional Shopify image
  @param avatar_asset {string} theme asset filename fallback
  @param block optional for editor attributes
{% endcomment %}
<article
  class="dm-testimonial-card"
  {% if block %}
    {{ block.shopify_attributes }}
  {% endif %}
>
  <div class="dm-testimonial-card__quote-icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
      <path d="M7 8a3 3 0 0 1 3-3h1v4H9a1 1 0 0 0-1 1v3H5V9a1 1 0 0 1 1-1zm9 0a3 3 0 0 1 3-3h1v4h-2a1 1 0 0 0-1 1v3h-3V9a1 1 0 0 1 1-1z"/>
    </svg>
  </div>

  <div class="dm-testimonial-card__top">
    {% render 'dm-testimonial-stars', size: 'lg' %}
    <h3 class="dm-testimonial-card__title">{{ title | escape }}</h3>
    <blockquote class="dm-testimonial-card__review">
      <p>“{{ review | escape }}”</p>
    </blockquote>
  </div>

  <hr class="dm-testimonial-card__divider">

  <div class="dm-testimonial-card__footer">
    {% if avatar != blank %}
      {{
        avatar
        | image_url: width: 128
        | image_tag:
          class: 'dm-testimonial-card__avatar',
          alt: customer_name,
          loading: 'lazy',
          widths: '64, 96, 128',
          sizes: '48px'
      }}
    {% elsif avatar_asset != blank %}
      <img
        class="dm-testimonial-card__avatar"
        src="{{ avatar_asset | asset_url }}"
        alt="{{ customer_name | escape }}"
        width="48"
        height="48"
        loading="lazy"
        decoding="async">
    {% endif %}
    <div class="dm-testimonial-card__meta">
      <span class="dm-testimonial-card__name">{{ customer_name | escape }}</span>
      <span class="dm-testimonial-card__location">{{ location | escape }}</span>
      {% render 'dm-testimonial-stars', size: 'sm' %}
    </div>
  </div>
</article>
