{% comment %}
  Three product videos — deep pink animated backdrop (below care highlights on before/after section).
{% endcomment %}
<style>
  .dm-ph-video-trio {
    --dm-vt-base: rgb(197, 98, 147);
    --dm-vt-deep: rgb(180, 86, 134);
    --dm-vt-rich: rgb(194, 102, 145);
    --dm-vt-bright: rgb(202, 119, 155);
    position: relative;
    width: 100%;
    min-width: 0;
    margin: 0 0 clamp(1.5rem, 4vw, 2.25rem);
    padding: clamp(2rem, 5vw, 3.25rem) max(16px, env(safe-area-inset-left, 0px)) clamp(2.25rem, 5vw, 3.5rem)
      max(16px, env(safe-area-inset-right, 0px));
    overflow: hidden;
    box-sizing: border-box;
    background-color: var(--dm-vt-base);
  }

  @media screen and (min-width: 768px) {
    .dm-ph-video-trio {
      padding-left: max(56px, env(safe-area-inset-left, 0px));
      padding-right: max(56px, env(safe-area-inset-right, 0px));
    }
  }

  /* Flush with care highlights above (no gap between white band and video block) */
  .dm-before-after > .dm-ph-care-highlights--above-slider + .dm-ph-video-trio {
    margin-top: 0;
    padding-top: 0;
  }

  .dm-ph-video-trio__aurora {
    position: absolute;
    inset: -40% -20%;
    z-index: 0;
    background: linear-gradient(
      125deg,
      var(--dm-vt-deep) 0%,
      var(--dm-vt-base) 22%,
      var(--dm-vt-rich) 48%,
      var(--dm-vt-bright) 72%,
      var(--dm-vt-deep) 100%
    );
    background-size: 280% 280%;
    animation: dm-ph-video-trio-aurora 18s ease-in-out infinite;
    opacity: 1;
    filter: blur(1px);
  }

  @keyframes dm-ph-video-trio-aurora {
    0%,
    100% {
      background-position: 0% 40%;
      transform: translate3d(0, 0, 0) scale(1);
    }
    33% {
      background-position: 100% 60%;
      transform: translate3d(2%, -1%, 0) scale(1.03);
    }
    66% {
      background-position: 40% 0%;
      transform: translate3d(-1%, 2%, 0) scale(1.02);
    }
  }

  .dm-ph-video-trio__orb {
    position: absolute;
    z-index: 0;
    border-radius: 50%;
    filter: blur(52px);
    opacity: 0.45;
    pointer-events: none;
    animation: dm-ph-video-trio-float 14s ease-in-out infinite;
  }

  .dm-ph-video-trio__orb--a {
    width: min(42vw, 380px);
    height: min(42vw, 380px);
    top: -12%;
    left: -8%;
    background: radial-gradient(circle at 30% 30%, rgba(199, 91, 135, 0.65), transparent 70%);
    animation-delay: -2s;
  }

  .dm-ph-video-trio__orb--b {
    width: min(38vw, 340px);
    height: min(38vw, 340px);
    bottom: -18%;
    right: -6%;
    background: radial-gradient(circle at 70% 60%, rgba(158, 58, 102, 0.55), transparent 72%);
    animation-delay: -5s;
    animation-duration: 17s;
  }

  .dm-ph-video-trio__orb--c {
    width: min(30vw, 260px);
    height: min(30vw, 260px);
    top: 35%;
    right: 8%;
    left: auto;
    background: radial-gradient(circle at 50% 50%, rgba(255, 140, 185, 0.35), transparent 68%);
    animation-delay: -8s;
    animation-duration: 20s;
  }

  @keyframes dm-ph-video-trio-float {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(12px, -18px, 0);
    }
  }

  .dm-ph-video-trio__grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.07;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
  }

  .dm-ph-video-trio__inner {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
  }

  .dm-ph-video-trio__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 3vw, 1.35rem);
  }

  @media screen and (min-width: 900px) {
    .dm-ph-video-trio__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }

  @media screen and (min-width: 600px) and (max-width: 899px) {
    .dm-ph-video-trio__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .dm-ph-video-trio__cell:last-child {
      grid-column: 1 / -1;
      max-width: min(100%, 520px);
      margin-left: auto;
      margin-right: auto;
    }
  }

  .dm-ph-video-trio__cell {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(20, 8, 14, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(255, 255, 255, 0.12) inset;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    aspect-ratio: 9 / 16;
    max-height: min(78vh, 640px);
    margin-left: auto;
    margin-right: auto;
    touch-action: pan-y;
  }

  .dm-ph-video-trio__cell video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: rgba(20, 8, 14, 0.35);
    pointer-events: none;
    -webkit-user-select: none;
    user-select: none;
  }

  .dm-ph-video-trio__fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 1rem;
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 700;
    text-align: center;
    background: rgba(20, 8, 14, 0.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .dm-ph-video-trio__cell.is-waiting-for-tap .dm-ph-video-trio__fallback {
    opacity: 1;
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .dm-ph-video-trio__aurora,
    .dm-ph-video-trio__orb {
      animation: none;
    }

    .dm-ph-video-trio__aurora {
      background-position: 50% 50%;
    }
  }
</style>

<section class="dm-ph-video-trio" aria-label="Product videos">
  <div class="dm-ph-video-trio__aurora" aria-hidden="true"></div>
  <div class="dm-ph-video-trio__orb dm-ph-video-trio__orb--a" aria-hidden="true"></div>
  <div class="dm-ph-video-trio__orb dm-ph-video-trio__orb--c" aria-hidden="true"></div>
  <div class="dm-ph-video-trio__orb dm-ph-video-trio__orb--b" aria-hidden="true"></div>
  <div class="dm-ph-video-trio__grain" aria-hidden="true"></div>

  <div class="dm-ph-video-trio__inner">
    <div class="dm-ph-video-trio__grid">
      <div class="dm-ph-video-trio__cell">
        <video
          muted
          defaultmuted
          playsinline
          webkit-playsinline
          x5-playsinline
          loop
          autoplay
          preload="auto"
          disablepictureinpicture
          disableremoteplayback
          controlslist="nodownload noplaybackrate noremoteplayback nofullscreen"
          x-webkit-airplay="deny"
          aria-label="Product video 1">
          <source src="{{ '2cf4080e-3535-4871-8bdd-01405f2327da (2).mp4' | asset_url }}" type="video/mp4">
        </video>
      </div>
      <div class="dm-ph-video-trio__cell">
        <video
          muted
          defaultmuted
          playsinline
          webkit-playsinline
          x5-playsinline
          loop
          autoplay
          preload="auto"
          disablepictureinpicture
          disableremoteplayback
          controlslist="nodownload noplaybackrate noremoteplayback nofullscreen"
          x-webkit-airplay="deny"
          aria-label="Product video 2">
          <source src="{{ '93ab5fb7-7579-46f4-a7e9-ca16782cb6f8.mp4' | asset_url }}" type="video/mp4">
        </video>
        <button class="dm-ph-video-trio__fallback" type="button" aria-label="Play product video 2">Tap to play</button>
      </div>
      <div class="dm-ph-video-trio__cell">
        <video
          muted
          defaultmuted
          playsinline
          webkit-playsinline
          x5-playsinline
          loop
          autoplay
          preload="auto"
          disablepictureinpicture
          disableremoteplayback
          controlslist="nodownload noplaybackrate noremoteplayback nofullscreen"
          x-webkit-airplay="deny"
          aria-label="Product video 3">
          <source src="{{ '87376108-b3bb-44d2-87e4-999646d533f8.mp4' | asset_url }}" type="video/mp4">
        </video>
        <button class="dm-ph-video-trio__fallback" type="button" aria-label="Play product video 3">Tap to play</button>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.currentScript.previousElementSibling;
    if (!root || !root.classList.contains('dm-ph-video-trio')) return;

    const videos = Array.from(root.querySelectorAll('video'));
    const tryPlay = (video) => {
      video.muted = true;
      video.defaultMuted = true;
      video.controls = false;
      video.disablePictureInPicture = true;
      video.disableRemotePlayback = true;
      video.setAttribute('muted', '');
      video.setAttribute('playsinline', '');
      video.setAttribute('webkit-playsinline', '');
      video.setAttribute('x5-playsinline', '');
      video.setAttribute('controlslist', 'nodownload noplaybackrate noremoteplayback nofullscreen');
      video.setAttribute('x-webkit-airplay', 'deny');
      if (video.readyState === 0) video.load();

      const playAttempt = video.play();
      if (playAttempt && typeof playAttempt.catch === 'function') {
        playAttempt
          .then(() => video.closest('.dm-ph-video-trio__cell')?.classList.remove('is-waiting-for-tap'))
          .catch(() => video.closest('.dm-ph-video-trio__cell')?.classList.add('is-waiting-for-tap'));
      }
    };

    const playVisibleVideos = () => videos.forEach(tryPlay);

    videos.forEach((video) => {
      video.addEventListener('webkitbeginfullscreen', () => {
        if (typeof video.webkitExitFullscreen === 'function') {
          window.setTimeout(() => video.webkitExitFullscreen(), 0);
        }
      });
    });

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) tryPlay(entry.target);
          });
        },
        { rootMargin: '160px 0px' }
      );
      videos.forEach((video) => observer.observe(video));
    } else {
      playVisibleVideos();
    }

    root.addEventListener('click', (event) => {
      const button = event.target.closest('.dm-ph-video-trio__fallback');
      if (!button) return;
      const video = button.closest('.dm-ph-video-trio__cell')?.querySelector('video');
      if (video) tryPlay(video);
    });

    ['touchstart', 'pointerdown', 'pageshow', 'visibilitychange'].forEach((eventName) => {
      window.addEventListener(eventName, playVisibleVideos, { passive: true, once: eventName !== 'visibilitychange' });
    });
  })();
</script>
