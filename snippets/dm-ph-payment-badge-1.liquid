{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_mobile | default: blockMarginTop_responsive_range_desktop }}px;
    --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_mobile | default: blockMarginBottom_responsive_range_desktop }}px;
    --{{ block.id }}--paymentBadgeBadgeWidth_responsive_range: {{ paymentBadgeBadgeWidth_responsive_range_mobile | default: paymentBadgeBadgeWidth_responsive_range_desktop }}px;
    --{{ block.id }}--paymentBadgeDirection_responsive_select: {{ paymentBadgeDirection_responsive_select_mobile | default: paymentBadgeDirection_responsive_select_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_desktop }}px;
      --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_desktop }}px;
      --{{ block.id }}--paymentBadgeBadgeWidth_responsive_range: {{ paymentBadgeBadgeWidth_responsive_range_desktop }}px;
      --{{ block.id }}--paymentBadgeDirection_responsive_select: {{ paymentBadgeDirection_responsive_select_desktop }};
    }
  }
</style>


<div
  {{ block.shopify_attributes }}
  class="relative transition-all duration-150 ease-in-out flex "
  style="margin-top: var(--{{ block.id }}--blockMarginTop_responsive_range); margin-bottom: var(--{{ block.id }}--blockMarginBottom_responsive_range);">
  <div class="flex flex-wrap gap-2 w-full min-h-5 {% if paymentBadgeHide_checkbox %}dm-hidden{% else %}{% endif %}" style="justify-content: var(--{{ block.id }}--paymentBadgeDirection_responsive_select);">
    {%- for badge in settings.dm_payment_badge_type -%}
      <img src="{{ badge | payment_type_img_url }}" style="width: var(--{{ block.id }}--paymentBadgeBadgeWidth_responsive_range);" />
    {%- endfor -%}
  </div>
</div>