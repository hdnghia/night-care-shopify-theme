{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_mobile | default: blockMarginTop_responsive_range_desktop }}px;
    --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_mobile | default: blockMarginBottom_responsive_range_desktop }}px;
    --{{ block.id }}--faqTitleTextAlign_text_alignment: {{ faqTitleTextAlign_text_alignment_mobile | default: faqTitleTextAlign_text_alignment_desktop }};
    --{{ block.id }}--faqIconIconSize_responsive_range: {{ faqIconIconSize_responsive_range_mobile | default: faqIconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--faqContentTextAlign_text_alignment: {{ faqContentTextAlign_text_alignment_mobile | default: faqContentTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_desktop }}px;
      --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_desktop }}px;
      --{{ block.id }}--faqTitleTextAlign_text_alignment: {{ faqTitleTextAlign_text_alignment_desktop }};
      --{{ block.id }}--faqIconIconSize_responsive_range: {{ faqIconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--faqContentTextAlign_text_alignment: {{ faqContentTextAlign_text_alignment_desktop }};
    }
  }
</style>

<script src="{{ 'dm-accordion.js' | asset_url }}" defer="defer"></script>
<div
  {{ block.shopify_attributes }}
  class="relative transition-all duration-150 ease-in-out flex "
  style="margin-top: var(--{{ block.id }}--blockMarginTop_responsive_range); margin-bottom: var(--{{ block.id }}--blockMarginBottom_responsive_range);">


  {% assign accordion_style_value = settings.card_style %}
  {% if faqStyle_select != blank %}
    {% assign accordion_style_value = faqStyle_select %}
  {% endif %}


  {%- capture accordion_classes -%}
    {% render 'dm_classname_utils'
     , type: "accordion",
     accordion_size: faqSize_select,
     accordion_variant: accordion_style_value %}
  {%- endcapture -%}

  {%- style -%}
    .faq_{{ block.id }}--dm-accordion {
      width: 100%;
      display: flex;
      flex-direction: column;
      max-width: none;
      overflow: hidden;
      transition: all 0.4s ease-in-out;
      cursor: pointer;
    }

    .faq_{{ block.id }}--dm-accordion__intro {
      position: relative;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .faq_{{ block.id }}--dm-accordion__content {
      max-height: 0;
      overflow: hidden;
      will-change: max-height;
      transition: all 0.4s ease-in-out;
      opacity: 0;
    }

    .dm-accordion__active > .faq_{{ block.id }}--dm-accordion__content {
      opacity: 1;
    }

    :not(.dm-accordion__active) > .faq_{{ block.id }}--dm-accordion__content {
      padding-top: 0 !important;
    }

    .faq_{{ block.id }}--dm-accordion__intro [data-dm-element="icon"] {
      transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    .dm-accordion__active > .faq_{{ block.id }}--dm-accordion__intro [data-dm-element="icon"] {
      rotate: {% if faqRotateIcon_checkbox == true %}
        180deg;
      {% else %}
        0;
      {% endif %}
    }
  {%- endstyle -%}

  <dm-accordion class="faq_{{ block.id }}--dm-accordion w-full border-border rounded-sm bg-card {{ accordion_classes | strip }}" style="background-color: {{ faqAccordionBackground_color }}; {% if faqAccordionBorder_color != blank %} border-color: {{ faqAccordionBorder_color }}; {% endif %} {% if faqAccordionBorder_number != blank %} border-width: {{ faqAccordionBorder_number }}px; {% endif %} {% if faqAccordionRadius_number != blank %} border-radius: {{ faqAccordionRadius_number }}px; {% endif %}">
    <div class="faq_{{ block.id }}--dm-accordion__intro gap-2" id="accordion-intro">
      <p class="text-foreground {{ faqTitleTextStyle_font_mobile }} sm:{{ faqTitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--faqTitleTextAlign_text_alignment); color: {{ faqTitleTextColor_color }};">{{ faqTitle_text }}</p>

      {% unless faqIcon_icon == blank %}
        {% assign icon_text = faqIcon_icon | strip %}
        {% if icon_text contains "<svg" %}
          <div
            data-dm-element="icon"
            class="w-fit text-foreground"
            style="aspect-ratio: 1/1; color: {{ faqIconIconColor_color }}; width: var(--{{ block.id }}--faqIconIconSize_responsive_range); height: var(--{{ block.id }}--faqIconIconSize_responsive_range);">{{ faqIcon_icon }}</div>
        {% else %}
          <div
            data-dm-element="icon"
            class="w-fit text-foreground"
            style="line-height: 100%; font-size: var(--{{ block.id }}--faqIconIconSize_responsive_range);">{{ faqIcon_icon }}</div>
        {% endif %}
      {% endunless %}

    </div>
    <div class="faq_{{ block.id }}--dm-accordion__content" id="accordion-content">
      <p class="text-foreground {{ faqContentTextStyle_font_mobile }} sm:{{ faqContentTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--faqContentTextAlign_text_alignment); color: {{ faqContentTextColor_color }};">{{ faqContent_text }}</p>
    </div>
  </dm-accordion>

</div>