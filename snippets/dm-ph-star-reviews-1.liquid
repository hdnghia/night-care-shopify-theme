{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_mobile | default: blockMarginTop_responsive_range_desktop }}px;
    --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_mobile | default: blockMarginBottom_responsive_range_desktop }}px;
    --{{ block.id }}--starReviewsDirection_responsive_select: {{ starReviewsDirection_responsive_select_mobile | default: starReviewsDirection_responsive_select_desktop }};
    --{{ block.id }}--starReviewsIconIconSize_responsive_range: {{ starReviewsIconIconSize_responsive_range_mobile | default: starReviewsIconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--starReviewsTextTextAlign_text_alignment: {{ starReviewsTextTextAlign_text_alignment_mobile | default: starReviewsTextTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_desktop }}px;
      --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_desktop }}px;
      --{{ block.id }}--starReviewsDirection_responsive_select: {{ starReviewsDirection_responsive_select_desktop }};
      --{{ block.id }}--starReviewsIconIconSize_responsive_range: {{ starReviewsIconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--starReviewsTextTextAlign_text_alignment: {{ starReviewsTextTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div
  {{ block.shopify_attributes }}
  class="relative transition-all duration-150 ease-in-out "
  style="margin-top: var(--{{ block.id }}--blockMarginTop_responsive_range); margin-bottom: var(--{{ block.id }}--blockMarginBottom_responsive_range);">
  <div class="relative flex items-center " style="justify-content: var(--{{ block.id }}--starReviewsDirection_responsive_select);">

    <div class="flex flex-row gap-[1px]">
      {% if starReviewsIcon_icon %}
        {% unless starReviewsIcon_icon == blank %}
          {% assign icon_text = starReviewsIcon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="aspect-ratio: 1/1; color: {{ starReviewsIconIconColor_color }}; width: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range); height: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsIcon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="line-height: 100%; font-size: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsIcon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}

      {% if starReviewsIcon_icon %}
        {% unless starReviewsIcon_icon == blank %}
          {% assign icon_text = starReviewsIcon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="aspect-ratio: 1/1; color: {{ starReviewsIconIconColor_color }}; width: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range); height: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsIcon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="line-height: 100%; font-size: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsIcon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}

      {% if starReviewsIcon_icon %}
        {% unless starReviewsIcon_icon == blank %}
          {% assign icon_text = starReviewsIcon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="aspect-ratio: 1/1; color: {{ starReviewsIconIconColor_color }}; width: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range); height: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsIcon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="line-height: 100%; font-size: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsIcon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}

      {% if starReviewsIcon_icon %}
        {% unless starReviewsIcon_icon == blank %}
          {% assign icon_text = starReviewsIcon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="aspect-ratio: 1/1; color: {{ starReviewsIconIconColor_color }}; width: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range); height: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsIcon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="line-height: 100%; font-size: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsIcon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}

      {% if starReviewsIcon_icon %}
        {% unless starReviewsLastIcon_icon == blank %}
          {% assign icon_text = starReviewsLastIcon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="aspect-ratio: 1/1; color: {{ starReviewsIconIconColor_color }}; width: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range); height: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsLastIcon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="line-height: 100%; font-size: var(--{{ block.id }}--starReviewsIconIconSize_responsive_range);">{{ starReviewsLastIcon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}
    </div>


    <p class="text-foreground ml-2 {{ starReviewsTextTextStyle_font_mobile }} sm:{{ starReviewsTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--starReviewsTextTextAlign_text_alignment); color: {{ starReviewsTextTextColor_color }};">{{ starReviewsText_text }}</p>
  </div>
</div>