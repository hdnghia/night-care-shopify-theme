{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_mobile | default: blockMarginTop_responsive_range_desktop }}px;
    --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_mobile | default: blockMarginBottom_responsive_range_desktop }}px;
    --{{ block.id }}--iconText1IconIconSize_responsive_range: {{ iconText1IconIconSize_responsive_range_mobile | default: iconText1IconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--iconText1TextTextAlign_text_alignment: {{ iconText1TextTextAlign_text_alignment_mobile | default: iconText1TextTextAlign_text_alignment_desktop }};
    --{{ block.id }}--iconText2IconIconSize_responsive_range: {{ iconText2IconIconSize_responsive_range_mobile | default: iconText2IconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--iconText2TextTextAlign_text_alignment: {{ iconText2TextTextAlign_text_alignment_mobile | default: iconText2TextTextAlign_text_alignment_desktop }};
    --{{ block.id }}--iconText3IconIconSize_responsive_range: {{ iconText3IconIconSize_responsive_range_mobile | default: iconText3IconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--iconText3TextTextAlign_text_alignment: {{ iconText3TextTextAlign_text_alignment_mobile | default: iconText3TextTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_desktop }}px;
      --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_desktop }}px;
      --{{ block.id }}--iconText1IconIconSize_responsive_range: {{ iconText1IconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--iconText1TextTextAlign_text_alignment: {{ iconText1TextTextAlign_text_alignment_desktop }};
      --{{ block.id }}--iconText2IconIconSize_responsive_range: {{ iconText2IconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--iconText2TextTextAlign_text_alignment: {{ iconText2TextTextAlign_text_alignment_desktop }};
      --{{ block.id }}--iconText3IconIconSize_responsive_range: {{ iconText3IconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--iconText3TextTextAlign_text_alignment: {{ iconText3TextTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div
  {{ block.shopify_attributes }}
  class="relative transition-all duration-150 ease-in-out "
  style="margin-top: var(--{{ block.id }}--blockMarginTop_responsive_range); margin-bottom: var(--{{ block.id }}--blockMarginBottom_responsive_range);">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 gap-y-2 ">
    <div class="flex flex-row items-center gap-2">
      {% if iconText1Icon_icon %}
        {% unless iconText1Icon_icon == blank %}
          {% assign icon_text = iconText1Icon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="aspect-ratio: 1/1; color: {{ iconText1IconIconColor_color }}; width: var(--{{ block.id }}--iconText1IconIconSize_responsive_range); height: var(--{{ block.id }}--iconText1IconIconSize_responsive_range);">{{ iconText1Icon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="line-height: 100%; font-size: var(--{{ block.id }}--iconText1IconIconSize_responsive_range);">{{ iconText1Icon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}
      <p class="text-foreground {{ iconText1TextTextStyle_font_mobile }} sm:{{ iconText1TextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--iconText1TextTextAlign_text_alignment); color: {{ iconText1TextTextColor_color }};">{{ iconText1Text_text }}</p>
    </div>
    <div class="flex flex-row items-center gap-2">
      {% if iconText2Icon_icon %}
        {% unless iconText2Icon_icon == blank %}
          {% assign icon_text = iconText2Icon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="aspect-ratio: 1/1; color: {{ iconText2IconIconColor_color }}; width: var(--{{ block.id }}--iconText2IconIconSize_responsive_range); height: var(--{{ block.id }}--iconText2IconIconSize_responsive_range);">{{ iconText2Icon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="line-height: 100%; font-size: var(--{{ block.id }}--iconText2IconIconSize_responsive_range);">{{ iconText2Icon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}
      <p class="text-foreground {{ iconText2TextTextStyle_font_mobile }} sm:{{ iconText2TextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--iconText2TextTextAlign_text_alignment); color: {{ iconText2TextTextColor_color }};">{{ iconText2Text_text }}</p>
    </div>
    <div class="flex flex-row items-center gap-2">
      {% if iconText3Icon_icon %}
        {% unless iconText3Icon_icon == blank %}
          {% assign icon_text = iconText3Icon_icon | strip %}
          {% if icon_text contains "<svg" %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="aspect-ratio: 1/1; color: {{ iconText3IconIconColor_color }}; width: var(--{{ block.id }}--iconText3IconIconSize_responsive_range); height: var(--{{ block.id }}--iconText3IconIconSize_responsive_range);">{{ iconText3Icon_icon }}</div>
          {% else %}
            <div
              data-dm-element="icon"
              class="w-fit text-foreground"
              style="line-height: 100%; font-size: var(--{{ block.id }}--iconText3IconIconSize_responsive_range);">{{ iconText3Icon_icon }}</div>
          {% endif %}
        {% endunless %}
    {% else %}
      {% endif %}
      <p class="text-foreground {{ iconText3TextTextStyle_font_mobile }} sm:{{ iconText3TextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--iconText3TextTextAlign_text_alignment); color: {{ iconText3TextTextColor_color }};">{{ iconText3Text_text }}</p>
    </div>
  </div>
</div>