{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--iconIconSize_responsive_range: {{ iconIconSize_responsive_range_mobile | default: iconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--titleTextAlign_text_alignment: {{ titleTextAlign_text_alignment_mobile | default: titleTextAlign_text_alignment_desktop }};
    --{{ block.id }}--descriptionTextAlign_text_alignment: {{ descriptionTextAlign_text_alignment_mobile | default: descriptionTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--iconIconSize_responsive_range: {{ iconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--titleTextAlign_text_alignment: {{ titleTextAlign_text_alignment_desktop }};
      --{{ block.id }}--descriptionTextAlign_text_alignment: {{ descriptionTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div {{ block.shopify_attributes }} class="relative transition-all duration-150 ease-in-out ">


  {% assign card_style_value = settings.card_style %}
  {% if cardStyle_select != blank %}
    {% assign card_style_value = cardStyle_select %}
  {% endif %}


  {%- capture card_classes -%}
    {% render 'dm_classname_utils'
     , type: "card",
     card_variant: card_style_value,
     card_size: cardSize_select %}
  {%- endcapture -%}


  <div class="overflow-hidden rounded-md border-solid  transition-all duration-150 ease-in-out bg-card border-border flex gap-x-4 {{ card_classes | strip }}" style="background-color: {{ cardBackground_color }}; border-color: {{ cardBorder_color }}; border-width: {{ cardBorderWidth_number }}px; border-radius: {{ cardRadius_range }}px;">
    {% if icon_icon %}
      {% unless icon_icon == blank %}
        {% assign icon_text = icon_icon | strip %}
        {% if icon_text contains "<svg" %}
          <div
            data-dm-element="icon"
            class="w-fit text-primary"
            style="aspect-ratio: 1/1; color: {{ iconIconColor_color }}; width: var(--{{ block.id }}--iconIconSize_responsive_range); height: var(--{{ block.id }}--iconIconSize_responsive_range);">{{ icon_icon }}</div>
        {% else %}
          <div
            data-dm-element="icon"
            class="w-fit text-primary"
            style="line-height: 100%; font-size: var(--{{ block.id }}--iconIconSize_responsive_range);">{{ icon_icon }}</div>
        {% endif %}
      {% endunless %}
  {% else %}
    {% endif %}
    <div class="flex flex-col gap-y-1 items-start">
      <h3 class="text-card-foreground {{ titleTextStyle_font_mobile }} sm:{{ titleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--titleTextAlign_text_alignment); color: {{ titleTextColor_color }};">{{ title_text }}</h3>
      <p class="text-muted-foreground {{ descriptionTextStyle_font_mobile }} sm:{{ descriptionTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--descriptionTextAlign_text_alignment); color: {{ descriptionTextColor_color }};">{{ description_text }}</p>
    </div>
  </div>
</div>