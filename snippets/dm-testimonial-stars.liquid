{% comment %}
  Decorative star row. @param size {string} lg | sm
{% endcomment %}
{% liquid
  if size == 'lg'
    assign dim = 20
  else
    assign dim = 14
  endif
%}
<div class="dm-testimonial-stars dm-testimonial-stars--{{ size }}" aria-hidden="true">
  {% for _ in (1..5) %}
    <svg xmlns="http://www.w3.org/2000/svg" width="{{ dim }}" height="{{ dim }}" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  {% endfor %}
</div>
