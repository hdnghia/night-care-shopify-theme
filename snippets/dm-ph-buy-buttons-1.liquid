{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');

  .dm-ph-buy-buttons-1 {
    font-family: 'Poppins', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
    font-size: 0.875rem;
    -webkit-font-smoothing: antialiased;
  }

  @media screen and (min-width: 768px) {
    .dm-ph-buy-buttons-1 {
      font-size: 0.9375rem;
    }
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__divider,
  .dm-ph-buy-buttons-1 .dm-offer-card,
  .dm-ph-buy-buttons-1 .dm-offer-payments,
  .dm-ph-buy-buttons-1 .dm-hero-trust-row,
  .dm-ph-buy-buttons-1 .product-form__buttons {
    font-family: inherit;
  }

  /* Bundle option cards — soft pink panels (solid, no gradient) */
  .dm-ph-buy-buttons-1 .dm-offer-card {
    background: #fff5f9 !important;
    background-image: none !important;
    border-color: color-mix(in srgb, #c45b87 32%, #f5d0dc 68%) !important;
    box-shadow: 0 2px 14px rgba(196, 91, 135, 0.08) !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card:hover {
    background: #ffecf3 !important;
    background-image: none !important;
    border-color: color-mix(in srgb, #b84e7a 42%, #f0c4d4 58%) !important;
    box-shadow: 0 8px 22px rgba(184, 78, 122, 0.14) !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card:has(input:checked) {
    background: #ffdce8 !important;
    background-image: none !important;
    border-color: color-mix(in srgb, #a84472 55%, #e8b8cc 45%) !important;
    box-shadow: 0 10px 28px rgba(168, 68, 114, 0.18) !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__divider span {
    font-size: clamp(0.95rem, 2vw, 1.35rem) !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card__title {
    font-size: clamp(1rem, 1.9vw, 1.28rem) !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card__unit {
    font-size: 0.8125rem !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card__spec-line {
    font-size: 0.78rem !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card__spec-ship {
    font-size: 0.75rem !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card__price strong {
    font-size: clamp(1.1rem, 2vw, 1.42rem) !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card__price s {
    font-size: 0.82rem !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card__save {
    font-size: 0.72rem !important;
    padding: 6px 10px !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-card__ribbon {
    font-size: 0.78rem !important;
  }

  .dm-ph-buy-buttons-1 .product-form__buttons .dropmagic-text,
  .dm-ph-buy-buttons-1 .product-form__buttons p {
    font-size: 0.8125rem !important;
  }

  @media screen and (min-width: 768px) {
    .dm-ph-buy-buttons-1 .product-form__buttons .dropmagic-text,
    .dm-ph-buy-buttons-1 .product-form__buttons p {
      font-size: 0.875rem !important;
    }
  }

  .dm-ph-buy-buttons-1 .dm-hero-trust-row span {
    font-size: 0.75rem !important;
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__timer {
    margin-top: 10px;
    margin-bottom: 6px;
    max-width: 100%;
    flex-wrap: wrap;
    gap: 10px 12px;
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__timer-icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    color: inherit;
    opacity: 0.95;
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__timer-icon svg {
    display: block;
    width: 1.15em;
    height: 1.15em;
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__timer-label {
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__timer-time-group {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__timer-value {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    min-width: 3.25em;
    text-align: center;
  }

  .dm-ph-buy-buttons-1 .dm-offer-stack__timer-emoji {
    display: inline-block;
    line-height: 1;
    font-size: 1.05em;
    translate: 0 -0.05em;
  }

  /* Add to cart — solid deep pink, no gradient */
  .dm-ph-buy-buttons-1 .product-form__buttons button[type='submit'],
  .dm-ph-buy-buttons-1 .product-form__buttons button[name='add'] {
    background: #9e3a66 !important;
    background-image: none !important;
    color: #fff !important;
    border: 0 !important;
    box-shadow: 0 4px 14px rgba(158, 58, 102, 0.28) !important;
  }

  .dm-ph-buy-buttons-1 .product-form__buttons button[type='submit']:hover,
  .dm-ph-buy-buttons-1 .product-form__buttons button[name='add']:hover {
    background: #a1436d !important;
    background-image: none !important;
    color: #fff !important;
    box-shadow: 0 8px 22px rgba(133, 45, 85, 0.32) !important;
  }

  .dm-ph-buy-buttons-1 .product-form__buttons button[type='submit']:active,
  .dm-ph-buy-buttons-1 .product-form__buttons button[name='add']:active {
    background:rgb(183, 107, 144) !important;
    background-image: none !important;
  }

  .dm-ph-buy-buttons-1 .product-form__buttons button[type='submit']:focus-visible,
  .dm-ph-buy-buttons-1 .product-form__buttons button[name='add']:focus-visible {
    outline: 2px solid #fff !important;
    outline-offset: 3px !important;
  }

  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_mobile | default: blockMarginTop_responsive_range_desktop }}px;
    --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_mobile | default: blockMarginBottom_responsive_range_desktop }}px;
    --{{ block.id }}--buyButtonTextTextAlign_text_alignment: {{ buyButtonTextTextAlign_text_alignment_mobile | default: buyButtonTextTextAlign_text_alignment_desktop }};
    --{{ block.id }}--buyButtonIconIconSize_responsive_range: {{ buyButtonIconIconSize_responsive_range_mobile | default: buyButtonIconIconSize_responsive_range_desktop }}px;
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_desktop }}px;
      --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_desktop }}px;
      --{{ block.id }}--buyButtonTextTextAlign_text_alignment: {{ buyButtonTextTextAlign_text_alignment_desktop }};
      --{{ block.id }}--buyButtonIconIconSize_responsive_range: {{ buyButtonIconIconSize_responsive_range_desktop }}px;
    }
  }
</style>

<script src="{{ 'dm-product-form.js' | asset_url }}" defer="defer"></script>
<div
  {{ block.shopify_attributes }}
  class="dm-ph-buy-buttons-1 relative transition-all duration-150 ease-in-out w-full block "
  style="margin-top: var(--{{ block.id }}--blockMarginTop_responsive_range); margin-bottom: var(--{{ block.id }}--blockMarginBottom_responsive_range);">


  {%- capture button_classes -%}
    {% render 'dm_classname_utils'
     , type: "button",
     button_style: settings.button_style,
     button_variant: buyButtonButtonVariant_select,
     button_size: buyButtonButtonSize_select,
     button_width: "full" %}
  {%- endcapture -%}

  {% if buyButtonButtonLink_link == "#add-to-cart" or buyButtonButtonLink_link == nil %}
    {% if product != nil %}
      <!-- If add to cart we render the form -->
      <dm-product-form class="w-full">
        {%- unless product_form_id -%}
          {% assign product_form_id = 'product-form-dm-ph-buy-buttons-1' | append: section.id %}
        {%- endunless -%}
        {%- form 'product',
 product,
 id: product_form_id,
 class: 'form',
 novalidate: 'novalidate',
 data-type: 'add-to-cart-form'
 -%}
          <input
            type="hidden"
            name="id"
            class="product-variant-id"
            value="{{ product.selected_or_first_available_variant.id }}"
            {% if section.settings.skip_cart %}data-skip-cart="true"{% endif %}>
          {% if buyButtonShowBundle_checkbox %}
            {%- liquid
              assign current_variant = product.selected_or_first_available_variant
              assign unit_price = current_variant.price
              assign unit_compare_price = current_variant.compare_at_price | default: current_variant.price
              assign product_image = product.featured_image | default: product.images.first
              assign has_bundle_variants = false
              if product.variants.size >= 3
                assign has_bundle_variants = true
              endif
            -%}
            <input type="hidden" name="quantity" value="{% if has_bundle_variants %}1{% else %}4{% endif %}" data-dm-offer-quantity>
            <div class="dm-offer-stack" aria-label="Bundle offers">
              <div class="dm-offer-stack__divider">
                <span>Buy More, Save More</span>
              </div>
              <div
                class="dm-offer-stack__timer"
                role="timer"
                aria-live="polite"
                aria-atomic="true"
                aria-label="Limited time offer">
                <span class="dm-offer-stack__timer-label" id="dm-offer-timer-label-{{ block.id }}">Hurry! Offers end in</span>
                <span class="dm-offer-stack__timer-time-group">
                  <span class="dm-offer-stack__timer-value" data-dm-offer-countdown>04:26</span>
                  <span class="dm-offer-stack__timer-emoji" aria-hidden="true">⏰</span>
                </span>
              </div>

              {%- assign bundle_quantities = '2,4,6' | split: ',' -%}
              {%- for bundle_quantity_value in bundle_quantities -%}
                  {%- liquid
                    assign bundle_quantity = bundle_quantity_value | plus: 0
                    assign paid_units = bundle_quantity | divided_by: 2
                    assign offer_variant = current_variant
                    assign offer_image_asset = 'dm-bundle-pack-2.png'
                    assign form_quantity = bundle_quantity
                    assign bundle_title = 'Buy 1 Get 1 Free'
                    assign bundle_price = 3999
                    assign bundle_compare = 9998
                    assign per_unit_price = 1999
                    if has_bundle_variants
                      assign offer_variant = product.variants[forloop.index0]
                      assign form_quantity = 1
                      assign bundle_price = offer_variant.price
                      if offer_variant.compare_at_price
                        assign bundle_compare = offer_variant.compare_at_price
                      else
                        assign bundle_compare = unit_compare_price | times: bundle_quantity
                      endif
                      assign per_unit_price = bundle_price | divided_by: bundle_quantity
                    else
                      if bundle_quantity == 4
                        assign bundle_price = 6999
                        assign bundle_compare = 19996
                        assign per_unit_price = 1750
                      elsif bundle_quantity == 6
                        assign bundle_price = 8998
                        assign bundle_compare = 29994
                        assign per_unit_price = 1500
                      endif
                    endif
                    assign bundle_savings = bundle_compare | minus: bundle_price
                    if has_bundle_variants == false and bundle_quantity == 6
                      assign bundle_savings = 20995
                    endif
                    assign card_class = 'dm-offer-card'
                    assign bundle_tier_count = 1
                    if bundle_quantity == 4
                      assign bundle_tier_count = 2
                      assign card_class = card_class | append: ' dm-offer-card--popular'
                      assign bundle_title = 'Buy 2 Get 2 Free'
                      assign offer_image_asset = 'dm-bundle-pack-4.png'
                    elsif bundle_quantity == 6
                      assign bundle_tier_count = 3
                      assign card_class = card_class | append: ' dm-offer-card--best'
                      assign bundle_title = 'Buy 3 Get 3 Free'
                      assign offer_image_asset = 'dm-bundle-pack-6.png'
                    endif
                  -%}
                  <label class="{{ card_class }}">
                    <input
                      type="radio"
                      name="dm_bundle_offer"
                      value="{{ forloop.index }}"
                      data-dm-offer-input
                      data-variant-id="{{ offer_variant.id }}"
                      data-quantity="{{ form_quantity }}"
                      {% if bundle_quantity == 4 %}checked{% endif %}>
                    {% if bundle_quantity == 4 %}
                      <span class="dm-offer-card__ribbon">Most Popular</span>
                    {% elsif bundle_quantity == 6 %}
                      <span class="dm-offer-card__ribbon">Best Deal</span>
                    {% endif %}
                    <div class="dm-offer-card__main">
                      <span class="dm-offer-card__media" aria-hidden="true">
                        <img
                          src="{{ offer_image_asset | asset_url }}"
                          alt=""
                          width="120"
                          height="120"
                          loading="lazy">
                      </span>
                      <span class="dm-offer-card__body">
                        <span class="dm-offer-card__topline">
                          <span class="dm-offer-card__title">{{ bundle_title }}</span>
                          {% if bundle_savings > 0 %}
                            <span class="dm-offer-card__save">Save {{ bundle_savings | money }}</span>
                          {% endif %}
                        </span>
                        <span class="dm-offer-card__unit">Only {{ per_unit_price | money }} each</span>
                      </span>
                      <span class="dm-offer-card__price">
                        <strong>{{ bundle_price | money }}</strong>
                        {% if bundle_compare > bundle_price %}
                          <s>{{ bundle_compare | money }}</s>
                        {% endif %}
                      </span>
                    </div>
                    <div class="dm-offer-card__spec-footer">
                      <div class="dm-offer-card__spec-lines">
                        <span class="dm-offer-card__spec-line">
                          <svg
                            class="dm-offer-card__spec-icon-check"
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            focusable="false">
                            <path d="M20 6 9 17l-5-5"/>
                          </svg>
                          {{ bundle_tier_count }}x {{ product.title | truncate: 43, '' }}
                        </span>
                        <span class="dm-offer-card__spec-ship">
                          <svg
                            class="dm-offer-card__spec-icon-check"
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            focusable="false">
                            <path d="M20 6 9 17l-5-5"/>
                          </svg>
                          Free Shipping
                        </span>
                      </div>
                    </div>
                  </label>
              {%- endfor -%}
            </div>
            <script>
              (() => {
                const offerInputs = document.querySelectorAll('[data-dm-offer-input]');
                offerInputs.forEach((input) => {
                  if (input.dataset.bound === 'true') return;
                  input.dataset.bound = 'true';
                  const form = input.closest('form');
                  const applyOffer = () => {
                    if (!form || !input.checked) return;
                    const variantInput = form.querySelector('.product-variant-id');
                    const quantityInput = form.querySelector('[data-dm-offer-quantity]');
                    if (variantInput && input.dataset.variantId) {
                      variantInput.value = input.dataset.variantId;
                      variantInput.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                    if (quantityInput && input.dataset.quantity) {
                      quantityInput.value = input.dataset.quantity;
                    }
                  };
                  input.addEventListener('change', applyOffer);
                  applyOffer();
                });

                const timers = document.querySelectorAll('[data-dm-offer-countdown]');
                timers.forEach((timer) => {
                  if (timer.dataset.ready === 'true') return;
                  timer.dataset.ready = 'true';
                  let seconds = 266;
                  const root = timer.closest('.dm-offer-stack__timer');
                  const render = () => {
                    const minutes = String(Math.floor(seconds / 60)).padStart(2, '0');
                    const remainingSeconds = String(seconds % 60).padStart(2, '0');
                    const display = `${minutes}:${remainingSeconds}`;
                    timer.textContent = display;
                    if (root) {
                      const m = Number(minutes);
                      const s = Number(remainingSeconds);
                      root.setAttribute(
                        'aria-label',
                        `Deal ends in ${m} minute${m === 1 ? '' : 's'} and ${s} second${s === 1 ? '' : 's'}`
                      );
                    }
                    seconds = seconds > 0 ? seconds - 1 : 266;
                  };
                  render();
                  window.setInterval(render, 1000);
                });
              })();
            </script>
          {% endif %}
          <div class="product-form__buttons flex flex-col gap-2 w-full">
            {%- unless buyButtonShowOnlyDynamicCheckout_checkbox -%}
              <button
                name="add"
                type="submit"
                data-button-variant="{{ buyButtonButtonVariant_select }}"
                data-button-style="{{ settings.button_style }}"
                data-button-size="{{ buyButtonButtonSize_select }}"
                data-button-width="full"
                style="{% if buyButtonButtonRadius_number != nil %}border-radius: {{ buyButtonButtonRadius_number }}px;{% endif %}"
                class="gap-2 group rounded-md text-center inline-flex items-center justify-center transition-all duration-150 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 {{ button_classes | strip }} {% if buyButtonHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif buyButtonHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %} ">

                <p class="text-inherit {{ buyButtonTextTextStyle_font_mobile }} sm:{{ buyButtonTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--buyButtonTextTextAlign_text_alignment); color: {{ buyButtonTextTextColor_color }};">{{ buyButtonText_text }}</p>
                {% if buyButtonIcon_icon %}
                  {% unless buyButtonIcon_icon == blank %}
                    {% assign icon_text = buyButtonIcon_icon | strip %}
                    {% if icon_text contains "<svg" %}
                      <div
                        data-dm-element="icon"
                        class="w-fit translate-x-0 group-hover:translate-x-2 transition-transform text-inherit"
                        style="aspect-ratio: 1/1; color: {{ buyButtonIconIconColor_color }}; width: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range); height: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range);">{{ buyButtonIcon_icon }}</div>
                    {% else %}
                      <div
                        data-dm-element="icon"
                        class="w-fit translate-x-0 group-hover:translate-x-2 transition-transform text-inherit"
                        style="line-height: 100%; font-size: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range);">{{ buyButtonIcon_icon }}</div>
                    {% endif %}
                  {% endunless %}
              {% else %}
                {% endif %}

              </button>
            {%- endunless -%}
            {%- if buyButtonShowDynamicCheckout_checkbox or buyButtonShowOnlyDynamicCheckout_checkbox -%}
              {{ form | payment_button }}
            {%- endif -%}
          </div>
        {%- endform -%}
      </dm-product-form>
      <div class="dm-offer-payments" aria-label="Accepted payment methods">
        {{ 'visa' | payment_type_svg_tag }}
        {{ 'master' | payment_type_svg_tag }}
        {{ 'paypal' | payment_type_svg_tag }}
      </div>
      <div class="dm-hero-trust-row" aria-label="Purchase reassurance">
        <span>Secure checkout</span>
        <span>Fast shipping</span>
        <span>30-day support</span>
      </div>
    {% else %}
      <!-- No product available, render as a regular button -->
      {% unless buyButtonHide_responsive_checkbox_mobile and buyButtonHide_responsive_checkbox_desktop %}
        <a
          class="gap-2 group rounded-md text-center inline-flex items-center justify-center transition-all duration-150 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 {{ button_classes | strip }} {% if buyButtonHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif buyButtonHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}"
          href="#"
          data-button-variant="{{ buyButtonButtonVariant_select }}"
          data-button-style="{{ settings.button_style }}"
          data-button-size="{{ buyButtonButtonSize_select }}"
          data-button-width="full"
          style="{% if buyButtonButtonRadius_number != nil %}border-radius: {{ buyButtonButtonRadius_number }}px;{% endif %}">

          <p class="text-inherit {{ buyButtonTextTextStyle_font_mobile }} sm:{{ buyButtonTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--buyButtonTextTextAlign_text_alignment); color: {{ buyButtonTextTextColor_color }};">{{ buyButtonText_text }}</p>
          {% if buyButtonIcon_icon %}
            {% unless buyButtonIcon_icon == blank %}
              {% assign icon_text = buyButtonIcon_icon | strip %}
              {% if icon_text contains "<svg" %}
                <div
                  data-dm-element="icon"
                  class="w-fit translate-x-0 group-hover:translate-x-2 transition-transform text-inherit"
                  style="aspect-ratio: 1/1; color: {{ buyButtonIconIconColor_color }}; width: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range); height: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range);">{{ buyButtonIcon_icon }}</div>
              {% else %}
                <div
                  data-dm-element="icon"
                  class="w-fit translate-x-0 group-hover:translate-x-2 transition-transform text-inherit"
                  style="line-height: 100%; font-size: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range);">{{ buyButtonIcon_icon }}</div>
              {% endif %}
            {% endunless %}
        {% else %}
          {% endif %}

        </a>
      {% endunless %}
    {% endif %}

  {% else %}
    {% unless buyButtonHide_responsive_checkbox_mobile and buyButtonHide_responsive_checkbox_desktop %}
      <!-- If link we put an <a> tag -->
      <a
        class="gap-2 group rounded-md text-center inline-flex items-center justify-center transition-all duration-150 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 {{ button_classes | strip }} {% if buyButtonHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif buyButtonHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}"
        href="{% if buyButtonButtonLink_link == "#scroll-to-product" %}#product-hero-section{% else %}{{ buyButtonButtonLink_link }}{% endif %}"
        data-button-variant="{{ buyButtonButtonVariant_select }}"
        data-button-style="{{ settings.button_style }}"
        data-button-size="{{ buyButtonButtonSize_select }}"
        data-button-width="full"
        style="{% if buyButtonButtonRadius_number != nil %}border-radius: {{ buyButtonButtonRadius_number }}px;{% endif %}">

        <p class="text-inherit {{ buyButtonTextTextStyle_font_mobile }} sm:{{ buyButtonTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--buyButtonTextTextAlign_text_alignment); color: {{ buyButtonTextTextColor_color }};">{{ buyButtonText_text }}</p>
        {% if buyButtonIcon_icon %}
          {% unless buyButtonIcon_icon == blank %}
            {% assign icon_text = buyButtonIcon_icon | strip %}
            {% if icon_text contains "<svg" %}
              <div
                data-dm-element="icon"
                class="w-fit translate-x-0 group-hover:translate-x-2 transition-transform text-inherit"
                style="aspect-ratio: 1/1; color: {{ buyButtonIconIconColor_color }}; width: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range); height: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range);">{{ buyButtonIcon_icon }}</div>
            {% else %}
              <div
                data-dm-element="icon"
                class="w-fit translate-x-0 group-hover:translate-x-2 transition-transform text-inherit"
                style="line-height: 100%; font-size: var(--{{ block.id }}--buyButtonIconIconSize_responsive_range);">{{ buyButtonIcon_icon }}</div>
            {% endif %}
          {% endunless %}
      {% else %}
        {% endif %}

      </a>
    {% endunless %}
  {% endif %}

</div>
