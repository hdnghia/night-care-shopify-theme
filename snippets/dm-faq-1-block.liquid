{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--accordionTitleTextAlign_text_alignment: {{ accordionTitleTextAlign_text_alignment_mobile | default: accordionTitleTextAlign_text_alignment_desktop }};
    --{{ block.id }}--accordionIconIconSize_responsive_range: {{ accordionIconIconSize_responsive_range_mobile | default: accordionIconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--accordionContentTextAlign_text_alignment: {{ accordionContentTextAlign_text_alignment_mobile | default: accordionContentTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--accordionTitleTextAlign_text_alignment: {{ accordionTitleTextAlign_text_alignment_desktop }};
      --{{ block.id }}--accordionIconIconSize_responsive_range: {{ accordionIconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--accordionContentTextAlign_text_alignment: {{ accordionContentTextAlign_text_alignment_desktop }};
    }
  }
</style>

<script src="{{ 'dm-accordion.js' | asset_url }}" defer="defer"></script>
<div {{ block.shopify_attributes }} class="relative transition-all duration-150 ease-in-out ">


  {% assign accordion_style_value = settings.card_style %}
  {% if accordionStyle_select != blank %}
    {% assign accordion_style_value = accordionStyle_select %}
  {% endif %}


  {%- capture accordion_classes -%}
    {% render 'dm_classname_utils'
     , type: "accordion",
     accordion_size: accordionSize_select,
     accordion_variant: accordion_style_value %}
  {%- endcapture -%}

  {%- style -%}
    .accordion_{{ block.id }}--dm-accordion {
      width: 100%;
      display: flex;
      flex-direction: column;
      max-width: none;
      overflow: hidden;
      transition: all 0.4s ease-in-out;
      cursor: pointer;
    }

    .accordion_{{ block.id }}--dm-accordion__intro {
      position: relative;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .accordion_{{ block.id }}--dm-accordion__content {
      max-height: 0;
      overflow: hidden;
      will-change: max-height;
      transition: all 0.4s ease-in-out;
      opacity: 0;
    }

    .dm-accordion__active > .accordion_{{ block.id }}--dm-accordion__content {
      opacity: 1;
    }

    :not(.dm-accordion__active) > .accordion_{{ block.id }}--dm-accordion__content {
      padding-top: 0 !important;
    }

    .accordion_{{ block.id }}--dm-accordion__intro [data-dm-element="icon"] {
      transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    .dm-accordion__active > .accordion_{{ block.id }}--dm-accordion__intro [data-dm-element="icon"] {
      rotate: {% if accordionRotateIcon_checkbox == true %}
        180deg;
      {% else %}
        0;
      {% endif %}
    }
  {%- endstyle -%}

  <dm-accordion class="accordion_{{ block.id }}--dm-accordion rounded-sm w-full bg-card border-border {{ accordion_classes | strip }}" style="background-color: {{ accordionAccordionBackground_color }}; {% if accordionAccordionBorder_color != blank %} border-color: {{ accordionAccordionBorder_color }}; {% endif %} {% if accordionAccordionBorder_number != blank %} border-width: {{ accordionAccordionBorder_number }}px; {% endif %} {% if accordionAccordionRadius_number != blank %} border-radius: {{ accordionAccordionRadius_number }}px; {% endif %}">
    <div class="accordion_{{ block.id }}--dm-accordion__intro gap-2" id="accordion-intro">
      <p class="text-foreground {{ accordionTitleTextStyle_font_mobile }} sm:{{ accordionTitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--accordionTitleTextAlign_text_alignment); color: {{ accordionTitleTextColor_color }};">{{ accordionTitle_text }}</p>

      {% unless accordionIcon_icon == blank %}
        {% assign icon_text = accordionIcon_icon | strip %}
        {% if icon_text contains "<svg" %}
          <div
            data-dm-element="icon"
            class="w-fit text-foreground"
            style="aspect-ratio: 1/1; color: {{ accordionIconIconColor_color }}; width: var(--{{ block.id }}--accordionIconIconSize_responsive_range); height: var(--{{ block.id }}--accordionIconIconSize_responsive_range);">{{ accordionIcon_icon }}</div>
        {% else %}
          <div
            data-dm-element="icon"
            class="w-fit text-foreground"
            style="line-height: 100%; font-size: var(--{{ block.id }}--accordionIconIconSize_responsive_range);">{{ accordionIcon_icon }}</div>
        {% endif %}
      {% endunless %}

    </div>
    <div class="accordion_{{ block.id }}--dm-accordion__content" id="accordion-content">
      <p class="text-foreground {{ accordionContentTextStyle_font_mobile }} sm:{{ accordionContentTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--accordionContentTextAlign_text_alignment); color: {{ accordionContentTextColor_color }};">{{ accordionContent_text }}</p>
    </div>
  </dm-accordion>

</div>