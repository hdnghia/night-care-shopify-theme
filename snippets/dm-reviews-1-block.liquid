            <div class="relative max-w-full size-12 min-h-12 min-w-12 {% if avatarImageHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif avatarImageHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}" style="aspect-ratio: var(--{{ block.id }}--avatarImageAspectRatio_responsive_select); height: var(--{{ block.id }}--avatarHeight_responsive_range);">

              {% assign video_extensions = '.mp4,.webm,.mov,.avi,.avif,.m4v' | split: ',' %}
              {% assign is_valid_video = false %}
              {% for ext in video_extensions %}
                {% if avatar_media_video contains ext %}
                  {% assign is_valid_video = true %}
                  {% break %}
                {% endif %}
              {% endfor %}

              {% if avatar_media_video != blank and is_valid_video %}
                {% assign video_url = avatar_media_video | split: '?' | first %}
                {% assign video_params = avatar_media_video | split: '?' | last | split: '&' %}
                {% assign video_attrs = '' %}
                {% for param in video_params %}
                  {% assign key_value = param | split: '=' %}
                  {% assign key = key_value | first | downcase %}
                  {% assign value = key_value | last %}
                  {% case key %}
                    {% when 'loop' %}
                    {% assign video_attrs = video_attrs | append: ' loop' %}
                    {% when 'autoplay' %}
                    {% assign video_attrs = video_attrs | append: ' autoplay' %}
                    {% when 'muted' %}
                    {% assign video_attrs = video_attrs | append: ' muted' %}
                    {% when 'controls' %}
                    {% assign video_attrs = video_attrs | append: ' controls' %}
                    {% when 'playsinline' %}
                    {% assign video_attrs = video_attrs | append: ' playsinline' %}
                  {% endcase %}
                {% endfor %}
                <video
                  src="{{ video_url }}"
                  {% if avatar_media != blank %}poster="{{ avatar_media | image_url }}"{% endif %}
                  alt=" "
                  preload="metadata"
                  draggable="false"
                  class="border-solid h-full object-cover {{ media_classes | strip }} {{ width_classes }}"
                  style="{% if id_part != blank %}clip-path: url(#{{id_part}}); -webkit-clip-path: url(#{{id_part}});{% endif %} {% if avatarImageBorder_number != blank %} border-width: {{ avatarImageBorder_number }}px;{% endif %} {% if avatarImageBorder_color != blank %} border-color:{{ avatarImageBorder_color }};{% endif %} {% if avatarImageRadius_number != blank %} border-radius: {{ avatarImageRadius_number }}px;{% endif %} {% if avatarImagePosition_select != blank %} object-position: {{ avatarImagePosition_select }};{% endif %}"
                  {{ video_attrs }}></video>
              {% else %}
                <img
                  src="{{ avatar_media | image_url }}"
                  alt=" "
                  draggable="false"
                  loading="lazy"
                  class="border-solid h-full object-cover {{ media_classes | strip }} {{ width_classes }}"
                  style="{% if id_part != blank %}clip-path: url(#{{id_part}}); -webkit-clip-path: url(#{{id_part}});{% endif %} {% if avatarImageBorder_number != blank %} border-width: {{ avatarImageBorder_number }}px;{% endif %} {% if avatarImageBorder_color != blank %} border-color:{{ avatarImageBorder_color }};{% endif %} {% if avatarImageRadius_number != blank %} border-radius: {{ avatarImageRadius_number }}px;{% endif %} {% if avatarImagePosition_select != blank %} object-position: {{ avatarImagePosition_select }};{% endif %}">
              {% endif %}
            </div>
          {% else %}
            <div class="relative max-w-full size-12 min-h-12 min-w-12 {{ media_align_class }} {% if avatarImageHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif avatarImageHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}" style="aspect-ratio: var(--{{ block.id }}--avatarImageAspectRatio_responsive_select);">
              {{ 'image' | placeholder_svg_tag: width_classes | strip }}
            </div>
          {% endif %}
        {% endunless %}


        <div class="flex flex-col gap-y-[2px]">
          <p class="text-card-foreground {{ authorTextStyle_font_mobile }} sm:{{ authorTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--authorTextAlign_text_alignment); color: {{ authorTextColor_color }};">{{ author_text }}</p>
          <p class="text-muted-foreground {{ lastPurchaseTextStyle_font_mobile }} sm:{{ lastPurchaseTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--lastPurchaseTextAlign_text_alignment); color: {{ lastPurchaseTextColor_color }};">{{ lastPurchase_text }}</p>
        </div>
      </div>
    </div>
  </div>
</div>