{% comment %}
  Dropmagic Block | Version: 1.2.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_mobile | default: blockMarginTop_responsive_range_desktop }}px;
    --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_mobile | default: blockMarginBottom_responsive_range_desktop }}px;
    --{{ block.id }}--variantPickerOptionLabelTextAlign_text_alignment: {{ variantPickerOptionLabelTextAlign_text_alignment_mobile | default: variantPickerOptionLabelTextAlign_text_alignment_desktop }};
    --{{ block.id }}--variantPickerButtonTextTextAlign_text_alignment: {{ variantPickerButtonTextTextAlign_text_alignment_mobile | default: variantPickerButtonTextTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--blockMarginTop_responsive_range: {{ blockMarginTop_responsive_range_desktop }}px;
      --{{ block.id }}--blockMarginBottom_responsive_range: {{ blockMarginBottom_responsive_range_desktop }}px;
      --{{ block.id }}--variantPickerOptionLabelTextAlign_text_alignment: {{ variantPickerOptionLabelTextAlign_text_alignment_desktop }};
      --{{ block.id }}--variantPickerButtonTextTextAlign_text_alignment: {{ variantPickerButtonTextTextAlign_text_alignment_desktop }};
    }
  }
</style>

<script src="{{ 'dm-variant-selects.js' | asset_url }}" defer="defer"></script>
<div
  {{ block.shopify_attributes }}
  class="relative transition-all duration-150 ease-in-out w-full block "
  style="margin-top: var(--{{ block.id }}--blockMarginTop_responsive_range); margin-bottom: var(--{{ block.id }}--blockMarginBottom_responsive_range);">
  {% if variantPickertype_select == "pills" %}
    {%- unless product.has_only_default_variant -%}
      {%- assign product_form_id = 'product-form-' | append: section.id -%}
      <dm-variant-selects
        id="variant-selects-{{ section.id }}"
        class="no-js-hidden flex flex-col gap-3 "
        data-section="{{ section.id }}"
        data-url="{{ product.url }}">
        {%- for option in product.options_with_values -%}
          <fieldset class="flex flex-col">
            <legend
              data-dm-element="variant-picker-option-name"
              class="text-foreground mb-1 w-fit {{ variantPickerOptionLabelTextStyle_font_mobile }} sm:{{ variantPickerOptionLabelTextStyle_font_desktop }} dropmagic-text"
              style="text-align: var(--{{ block.id }}--variantPickerOptionLabelTextAlign_text_alignment); color: {{ variantPickerOptionLabelTextColor_color }};">{{ option.name }}</legend>
            {%- liquid
  assign variants_available_arr = product.variants | map: 'available'
  assign variants_option1_arr = product.variants | map: 'option1'
  assign variants_option2_arr = product.variants | map: 'option2'
  assign variants_option3_arr = product.variants | map: 'option3'
-%}
            <div class="flex flex-row gap-2 flex-wrap">
              {%- for value in option.values -%}
                {%- liquid
    assign option_disabled = true

    for option1_name in variants_option1_arr
      case option.position
        when 1
          if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 2
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 3
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == product.selected_or_first_available_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
      endcase
    endfor

    if value.swatch.image
      assign image_url = value.swatch.image | image_url: width: 50
      assign swatch_value = 'url(' | append: image_url | append: ')'
    elsif value.swatch.color
      assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
    else
      assign swatch_value = nil
    endif
  -%}

                {%- capture input_id -%}
                  {{ section.id }}-{{ option.position }}-{{ forloop.index0 -}}
                {%- endcapture -%}


                {% if option.selected_value == value %}
                  {% assign button_variant = variantPickerButtonSelectedButtonVariant_select %}
                {% else %}
                  {% assign button_variant = variantPickerButtonUnSelectedButtonVariant_select %}
                {% endif %}

                <input
                  type="radio"
                  id="{{ input_id }}"
                  name="{{ option.name }}"
                  value="{{ value | escape }}"
                  form="{{ product_form_id }}"
                  {% if option.selected_value == value %}
                  checked
                  {% endif %}
                  {% if option_disabled %}
                  class="disabled"
                  {% endif %}
                  style="clip: rect(0, 0, 0, 0); overflow: hidden; position: absolute; height: 1px; width: 1px;">
                <label
                  for="{{ input_id }}"
                  class="gap-2.5 group rounded-sm text-center inline-flex items-center justify-center transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
                  data-variant_button-variant="{{ button_variant }}"
                  data-variant_button-style="{{ settings.button_style }}"
                  data-variant_button-size="{{ variantPickerButtonButtonSize_select }}"
                  data-selected-variant="{{ variantPickerButtonSelectedButtonVariant_select }}"
                  data-unselected-variant="{{ variantPickerButtonUnSelectedButtonVariant_select }}"
                  style="cursor:pointer; {% if variantPickerButtonButtonRadius_number != nil %}border-radius: {{ variantPickerButtonButtonRadius_number }}px;{% endif %}">
                  <span class="text-inherit {{ variantPickerButtonTextTextStyle_font_mobile }} sm:{{ variantPickerButtonTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--variantPickerButtonTextTextAlign_text_alignment); color: {{ variantPickerButtonTextTextColor_color }};">{{ value }}</span>
                </label>
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}
        <script type="application/json">
          {{ product.variants | json }}
        </script>

      </dm-variant-selects>
    {%- endunless -%}
{% else %}
  {% endif %}
</div>