{% comment %}
  Dropmagic Block | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ block.id }}--iconIconSize_responsive_range: {{ iconIconSize_responsive_range_mobile | default: iconIconSize_responsive_range_desktop }}px;
    --{{ block.id }}--textTextAlign_text_alignment: {{ textTextAlign_text_alignment_mobile | default: textTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ block.id }}--iconIconSize_responsive_range: {{ iconIconSize_responsive_range_desktop }}px;
      --{{ block.id }}--textTextAlign_text_alignment: {{ textTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div {{ block.shopify_attributes }} class="relative transition-all duration-150 ease-in-out flex flex-row gap-2 items-center justify-start ">
  {% if icon_icon %}
    {% unless icon_icon == blank %}
      {% assign icon_text = icon_icon | strip %}
      {% if icon_text contains "<svg" %}
        <div
          data-dm-element="icon"
          class="w-fit text-primary"
          style="aspect-ratio: 1/1; color: {{ iconIconColor_color }}; width: var(--{{ block.id }}--iconIconSize_responsive_range); height: var(--{{ block.id }}--iconIconSize_responsive_range);">{{ icon_icon }}</div>
      {% else %}
        <div
          data-dm-element="icon"
          class="w-fit text-primary"
          style="line-height: 100%; font-size: var(--{{ block.id }}--iconIconSize_responsive_range);">{{ icon_icon }}</div>
      {% endif %}
    {% endunless %}
{% else %}
  {% endif %}
  <p class="text-foreground {{ textTextStyle_font_mobile }} sm:{{ textTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ block.id }}--textTextAlign_text_alignment); color: {{ textTextColor_color }};">{{ text_text }}</p>
</div>