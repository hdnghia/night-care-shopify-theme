{% comment %}
  RatingBreakdown — 5→1 rows with progress bars.
  @param total {number}
  @param c5..c1 {number} counts per star level
{% endcomment %}
{% liquid
  assign t = total | plus: 0
  if t < 1
    assign t = 1
  endif
%}
<div class="dm-rating-breakdown">
  {% assign rows = '5,4,3,2,1' | split: ',' %}
  {% for row in rows %}
    {% liquid
      case row
        when '5'
          assign cnt = c5 | plus: 0
        when '4'
          assign cnt = c4 | plus: 0
        when '3'
          assign cnt = c3 | plus: 0
        when '2'
          assign cnt = c2 | plus: 0
        else
          assign cnt = c1 | plus: 0
      endcase
      assign bar_pct = cnt | times: 100 | divided_by: t
    %}
    <div class="dm-rating-breakdown__row">
      <span class="dm-rating-breakdown__label">{{ row }}</span>
      <span class="dm-rating-breakdown__star-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </span>
      <div class="dm-rating-breakdown__bar-wrap">
        <div class="dm-rating-breakdown__bar" style="width: {{ bar_pct }}%;"></div>
      </div>
      <span class="dm-rating-breakdown__count">{{ cnt }}</span>
    </div>
  {% endfor %}
</div>
