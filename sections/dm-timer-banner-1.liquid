            </div>
            <p class="text-foreground {{ section.settings.countdownLabelTextStyle_font_mobile }} sm:{{ section.settings.countdownLabelTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--countdownLabelTextAlign_text_alignment); color: {{ section.settings.countdownLabelTextColor_color }};">{{ section.settings.countdownMinutesLabel_text }}</p>
