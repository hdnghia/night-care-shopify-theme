              class="!leading-none text-accent {{ section.settings.countdownContentTextStyle_font_mobile }} sm:{{ section.settings.countdownContentTextStyle_font_desktop }} dropmagic-text"
              style="text-align: var(--{{ section.id }}--countdownContentTextAlign_text_alignment); color: {{ section.settings.countdownContentTextColor_color }};">{{ 0 }}</p>

            <p class="!leading-none text-accent {{ section.settings.countdownLabelTextStyle_font_mobile }} sm:{{ section.settings.countdownLabelTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--countdownLabelTextAlign_text_alignment); color: {{ section.settings.countdownLabelTextColor_color }};">{{ section.settings.countdownMinutesLabel_text }}</p>
          </div>

          <div
            data-dm-counter-cards=""
            class="flex flex-col items-center border-solid rounded-md p-4 px-6 h-24 justify-center shadow-sm bg-card border-border"
            style="border-color: {{ section.settings.countdownBoxBorder_color }}; background-color: {{ section.settings.countdownBoxBackground_color }}; border-width: {{ section.settings.countdownBoxBorder_number }}px; border-radius: {{ section.settings.countdownBoxRadius_number }}px;">
