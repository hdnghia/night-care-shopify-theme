    <div class="w-fit  [&_[data-dm-counter-cards]]:!h-[40px] [&_[data-dm-counter]]:gap-x-1 [&_[data-dm-counter-cards]]:gap-0.5 [&_[data-dm-counter-cards]]:px-2 [&_[data-dm-counter-cards]]:rounded-none">
      {% if section.settings.countdowntype_select == "fullCards" %}
        <dm-counter
          data-dm-counter=""
          data-startingfrom="{{ section.settings.countdownStartingFrom_number }}"
          class="flex flex-row items-center gap-x-2">
          <div
            data-dm-counter-cards=""
            class="flex flex-col items-center border-solid rounded-md p-4 px-6 h-24 justify-center bg-card border-border"
            style="border-color: {{ section.settings.countdownBoxBorder_color }}; background-color: {{ section.settings.countdownBoxBackground_color }}; border-width: {{ section.settings.countdownBoxBorder_number }}px; border-radius: {{ section.settings.countdownBoxRadius_number }}px;">
            <p
              data-dm-element="data-dm-counter-hours"
              class="!leading-none text-accent {{ section.settings.countdownContentTextStyle_font_mobile }} sm:{{ section.settings.countdownContentTextStyle_font_desktop }} dropmagic-text"
              style="text-align: var(--{{ section.id }}--countdownContentTextAlign_text_alignment); color: {{ section.settings.countdownContentTextColor_color }};">{{ 10 }}</p>
            <p class="!leading-none text-accent {{ section.settings.countdownLabelTextStyle_font_mobile }} sm:{{ section.settings.countdownLabelTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--countdownLabelTextAlign_text_alignment); color: {{ section.settings.countdownLabelTextColor_color }};">{{ section.settings.countdownHoursLabel_text }}</p>
          </div>

          <div
