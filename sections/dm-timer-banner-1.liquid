              class="!leading-none text-accent {{ section.settings.countdownContentTextStyle_font_mobile }} sm:{{ section.settings.countdownContentTextStyle_font_desktop }} dropmagic-text"
              style="text-align: var(--{{ section.id }}--countdownContentTextAlign_text_alignment); color: {{ section.settings.countdownContentTextColor_color }};">{{ 0 }}</p>
            <p class="!leading-none text-accent {{ section.settings.countdownLabelTextStyle_font_mobile }} sm:{{ section.settings.countdownLabelTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--countdownLabelTextAlign_text_alignment); color: {{ section.settings.countdownLabelTextColor_color }};">{{ section.settings.countdownSecondsLabel_text }}</p>
          </div>
        </dm-counter>
    {% else %}
      {% endif %}
