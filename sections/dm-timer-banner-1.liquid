<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_mobile | default: section.settings.sectionPaddingTop_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_mobile | default: section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_mobile | default: section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_mobile | default: section.settings.sectionPaddingRight_responsive_range_desktop }}px;
    --{{ section.id }}--textTextAlign_text_alignment: {{ section.settings.textTextAlign_text_alignment_mobile | default: section.settings.textTextAlign_text_alignment_desktop }};
    --{{ section.id }}--countdownContentTextAlign_text_alignment: {{ section.settings.countdownContentTextAlign_text_alignment_mobile | default: section.settings.countdownContentTextAlign_text_alignment_desktop }};
    --{{ section.id }}--countdownLabelTextAlign_text_alignment: {{ section.settings.countdownLabelTextAlign_text_alignment_mobile | default: section.settings.countdownLabelTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_desktop }}px;
      --{{ section.id }}--textTextAlign_text_alignment: {{ section.settings.textTextAlign_text_alignment_desktop }};
      --{{ section.id }}--countdownContentTextAlign_text_alignment: {{ section.settings.countdownContentTextAlign_text_alignment_desktop }};
      --{{ section.id }}--countdownLabelTextAlign_text_alignment: {{ section.settings.countdownLabelTextAlign_text_alignment_desktop }};
    }
  }
</style>


