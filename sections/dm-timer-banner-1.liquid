          <span>:</span>
          <p
            data-dm-element="data-dm-counter-minutes"
            class="text-accent {{ section.settings.countdownContentTextStyle_font_mobile }} sm:{{ section.settings.countdownContentTextStyle_font_desktop }} dropmagic-text"
