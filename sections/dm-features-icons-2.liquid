      --{{ section.id }}--icon1IconSize_responsive_range: {{ section.settings.icon1IconSize_responsive_range_desktop }}px;
      --{{ section.id }}--title1TextAlign_text_alignment: {{ section.settings.title1TextAlign_text_alignment_desktop }};
      --{{ section.id }}--description1TextAlign_text_alignment: {{ section.settings.description1TextAlign_text_alignment_desktop }};
      --{{ section.id }}--icon2IconSize_responsive_range: {{ section.settings.icon2IconSize_responsive_range_desktop }}px;
      --{{ section.id }}--title2TextAlign_text_alignment: {{ section.settings.title2TextAlign_text_alignment_desktop }};
      --{{ section.id }}--description2TextAlign_text_alignment: {{ section.settings.description2TextAlign_text_alignment_desktop }};
      --{{ section.id }}--imageHeight_responsive_range: {{ section.settings.imageHeight_responsive_range_desktop }}px;
      --{{ section.id }}--imageImageAspectRatio_responsive_select: {{ section.settings.imageImageAspectRatio_responsive_select_desktop }};
      --{{ section.id }}--icon3IconSize_responsive_range: {{ section.settings.icon3IconSize_responsive_range_desktop }}px;
