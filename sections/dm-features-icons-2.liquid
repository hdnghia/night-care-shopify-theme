<div
  data-section-combination="{{section.settings.section_combination}}"
  class="block relative w-full transition-colors bg-background "
  style="background: {{ section.settings.sectionBackground_color }}; padding-top: var(--{{ section.id }}--sectionPaddingTop_responsive_range); padding-bottom: var(--{{ section.id }}--sectionPaddingBottom_responsive_range); padding-left: var(--{{ section.id }}--sectionPaddingLeft_responsive_range); padding-right: var(--{{ section.id }}--sectionPaddingRight_responsive_range);">
  <div class="mx-auto " style="max-width: {{ section.settings.sectionMaxWidth_number }}px;">
    <div class="mb-8 md:mb-12">
      <h2 class="text-foreground w-full {{ section.settings.titleTextStyle_font_mobile }} sm:{{ section.settings.titleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--titleTextAlign_text_alignment); color: {{ section.settings.titleTextColor_color }};">{{ section.settings.title_text }}</h2>
    </div>
    <div class="grid place-items-center gap-x-6 gap-y-4 sm:grid-cols-2 md:gap-y-16 lg:grid-cols-[1fr_1.5fr_1fr] lg:gap-x-12">
      <div class="grid w-full grid-cols-2 md:grid-cols-1 gap-x-6 md:gap-x-20 gap-y-12 md:gap-y-16">
        <div class="flex flex-col items-center text-center">
          <div class="mb-2">
            {% if section.settings.icon1_icon %}
              {% unless section.settings.icon1_icon == blank %}
                {% assign icon_text = section.settings.icon1_icon | strip %}
                {% if icon_text contains "<svg" %}
                  <div
                    data-dm-element="icon"
                    class="w-fit text-primary"
                    style="aspect-ratio: 1/1; color: {{ section.settings.icon1IconColor_color }}; width: var(--{{ section.id }}--icon1IconSize_responsive_range); height: var(--{{ section.id }}--icon1IconSize_responsive_range);">{{ section.settings.icon1_icon }}</div>
                {% else %}
                  <div
                    data-dm-element="icon"
                    class="w-fit text-primary"
                    style="line-height: 100%; font-size: var(--{{ section.id }}--icon1IconSize_responsive_range);">{{ section.settings.icon1_icon }}</div>
                {% endif %}
              {% endunless %}
          {% else %}
            {% endif %}
          </div>
          <h3 class="text-foreground mb-2 {{ section.settings.title1TextStyle_font_mobile }} sm:{{ section.settings.title1TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--title1TextAlign_text_alignment); color: {{ section.settings.title1TextColor_color }};">{{ section.settings.title1_text }}</h3>
          <p class="text-foreground {{ section.settings.description1TextStyle_font_mobile }} sm:{{ section.settings.description1TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--description1TextAlign_text_alignment); color: {{ section.settings.description1TextColor_color }};">{{ section.settings.description1_text }}</p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="mb-2">
            {% if section.settings.icon2_icon %}
              {% unless section.settings.icon2_icon == blank %}
                {% assign icon_text = section.settings.icon2_icon | strip %}
                {% if icon_text contains "<svg" %}
                  <div
                    data-dm-element="icon"
                    class="w-fit text-primary"
                    style="aspect-ratio: 1/1; color: {{ section.settings.icon2IconColor_color }}; width: var(--{{ section.id }}--icon2IconSize_responsive_range); height: var(--{{ section.id }}--icon2IconSize_responsive_range);">{{ section.settings.icon2_icon }}</div>
                {% else %}
                  <div
                    data-dm-element="icon"
                    class="w-fit text-primary"
                    style="line-height: 100%; font-size: var(--{{ section.id }}--icon2IconSize_responsive_range);">{{ section.settings.icon2_icon }}</div>
                {% endif %}
              {% endunless %}
          {% else %}
            {% endif %}
          </div>

          <h3 class="text-foreground mb-2 {{ section.settings.title2TextStyle_font_mobile }} sm:{{ section.settings.title2TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--title2TextAlign_text_alignment); color: {{ section.settings.title2TextColor_color }};">{{ section.settings.title2_text }}</h3>
          <p class="text-foreground {{ section.settings.description2TextStyle_font_mobile }} sm:{{ section.settings.description2TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--description2TextAlign_text_alignment); color: {{ section.settings.description2TextColor_color }};">{{ section.settings.description2_text }}</p>
        </div>
      </div>

      <div class="relative  w-full sm:col-span-2 lg:order-none lg:col-span-1">

        {% unless section.settings.imageImageHide_responsive_checkbox_mobile and section.settings.imageImageHide_responsive_checkbox_desktop %}

          {% assign media_style_value = settings.media_style %}
          {% if section.settings.imageImageStyle_select != blank %}
            {% assign media_style_value = section.settings.imageImageStyle_select %}
          {% endif %}
          {% if section.settings.imageImageMask_media_mask != blank %}
            {% assign media_style_value = "none" %}
          {% endif %}


          {%- capture media_classes -%}
            {% render 'dm_classname_utils'
             , type: "media",
             media_style: media_style_value %}
          {%- endcapture -%}

          {% if section.settings.imageImageMask_media_mask != blank %}
            {% assign id_part = section.settings.imageImageMask_media_mask | split: 'id="' | last | split: '"' | first %}
            <svg
              width="0"
              height="0"
              style="position: absolute;">
              <defs>{{ section.settings.imageImageMask_media_mask }}</defs>
            </svg>
          {% endif %}

          {% liquid
    if imageHeight_responsive_range_mobile != blank
      assign mobile_width = 'w-auto'
    else
      assign mobile_width = 'w-full'
    endif

    if imageHeight_responsive_range_desktop != blank
      assign desktop_width = 'sm:w-auto'
    else
      assign desktop_width = 'sm:w-full'
    endif

    assign width_classes = mobile_width | append: ' ' | append: desktop_width
  %}

          {% if section.settings.image_media != blank or section.settings.image_media_video != blank %}
            <div class="relative max-w-full  {% if section.settings.imageImageHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif section.settings.imageImageHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}" style="aspect-ratio: var(--{{ section.id }}--imageImageAspectRatio_responsive_select); height: var(--{{ section.id }}--imageHeight_responsive_range);">

              {% assign video_extensions = '.mp4,.webm,.mov,.avi,.avif,.m4v' | split: ',' %}
              {% assign is_valid_video = false %}
              {% for ext in video_extensions %}
                {% if section.settings.image_media_video contains ext %}
                  {% assign is_valid_video = true %}
                  {% break %}
                {% endif %}
              {% endfor %}

              {% if section.settings.image_media_video != blank and is_valid_video %}
                {% assign video_url = section.settings.image_media_video | split: '?' | first %}
                {% assign video_params = section.settings.image_media_video | split: '?' | last | split: '&' %}
                {% assign video_attrs = '' %}
                {% for param in video_params %}
                  {% assign key_value = param | split: '=' %}
                  {% assign key = key_value | first | downcase %}
                  {% assign value = key_value | last %}
                  {% case key %}
                    {% when 'loop' %}
                    {% assign video_attrs = video_attrs | append: ' loop' %}
                    {% when 'autoplay' %}
                    {% assign video_attrs = video_attrs | append: ' autoplay' %}
                    {% when 'muted' %}
                    {% assign video_attrs = video_attrs | append: ' muted' %}
                    {% when 'controls' %}
                    {% assign video_attrs = video_attrs | append: ' controls' %}
                    {% when 'playsinline' %}
                    {% assign video_attrs = video_attrs | append: ' playsinline' %}
                  {% endcase %}
                {% endfor %}
                <video
                  src="{{ video_url }}"
                  {% if section.settings.image_media != blank %}poster="{{ section.settings.image_media | image_url }}"{% endif %}
                  alt=" "
                  preload="metadata"
                  draggable="false"
                  class="border-solid h-full object-cover {{ media_classes | strip }} {{ width_classes }}"
                  style="{% if id_part != blank %}clip-path: url(#{{id_part}}); -webkit-clip-path: url(#{{id_part}});{% endif %} {% if section.settings.imageImageBorder_number != blank %} border-width: {{ section.settings.imageImageBorder_number }}px;{% endif %} {% if section.settings.imageImageBorder_color != blank %} border-color:{{ section.settings.imageImageBorder_color }};{% endif %} {% if section.settings.imageImageRadius_number != blank %} border-radius: {{ section.settings.imageImageRadius_number }}px;{% endif %} {% if section.settings.imageImagePosition_select != blank %} object-position: {{ section.settings.imageImagePosition_select }};{% endif %}"
                  {{ video_attrs }}></video>
              {% else %}
                <img
                  src="{{ section.settings.image_media | image_url }}"
                  alt=" "
                  draggable="false"
                  loading="lazy"
                  class="border-solid h-full object-cover {{ media_classes | strip }} {{ width_classes }}"
                  style="{% if id_part != blank %}clip-path: url(#{{id_part}}); -webkit-clip-path: url(#{{id_part}});{% endif %} {% if section.settings.imageImageBorder_number != blank %} border-width: {{ section.settings.imageImageBorder_number }}px;{% endif %} {% if section.settings.imageImageBorder_color != blank %} border-color:{{ section.settings.imageImageBorder_color }};{% endif %} {% if section.settings.imageImageRadius_number != blank %} border-radius: {{ section.settings.imageImageRadius_number }}px;{% endif %} {% if section.settings.imageImagePosition_select != blank %} object-position: {{ section.settings.imageImagePosition_select }};{% endif %}">
              {% endif %}
            </div>
          {% else %}
            <div class="relative max-w-full  {{ media_align_class }} {% if section.settings.imageImageHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif section.settings.imageImageHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}" style="aspect-ratio: var(--{{ section.id }}--imageImageAspectRatio_responsive_select);">
              {{ 'image' | placeholder_svg_tag: width_classes | strip }}
            </div>
          {% endif %}
        {% endunless %}

      </div>

      <div class="grid w-full grid-cols-2 md:grid-cols-1 gap-x-6 md:gap-x-20 gap-y-12 md:gap-y-16">
        <div class="flex flex-col items-center text-center">
          <div class="mb-2  ">
            {% if section.settings.icon3_icon %}
              {% unless section.settings.icon3_icon == blank %}
                {% assign icon_text = section.settings.icon3_icon | strip %}
                {% if icon_text contains "<svg" %}
                  <div
                    data-dm-element="icon"
                    class="w-fit text-primary"
                    style="aspect-ratio: 1/1; color: {{ section.settings.icon3IconColor_color }}; width: var(--{{ section.id }}--icon3IconSize_responsive_range); height: var(--{{ section.id }}--icon3IconSize_responsive_range);">{{ section.settings.icon3_icon }}</div>
                {% else %}
                  <div
                    data-dm-element="icon"
                    class="w-fit text-primary"
                    style="line-height: 100%; font-size: var(--{{ section.id }}--icon3IconSize_responsive_range);">{{ section.settings.icon3_icon }}</div>
                {% endif %}
              {% endunless %}
          {% else %}
            {% endif %}
          </div>

          <h3 class="text-foreground mb-2 {{ section.settings.title3TextStyle_font_mobile }} sm:{{ section.settings.title3TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--title3TextAlign_text_alignment); color: {{ section.settings.title3TextColor_color }};">{{ section.settings.title3_text }}</h3>
          <p class="text-foreground {{ section.settings.description3TextStyle_font_mobile }} sm:{{ section.settings.description3TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--description3TextAlign_text_alignment); color: {{ section.settings.description3TextColor_color }};">{{ section.settings.description3_text }}</p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div class="mb-2">
            {% if section.settings.icon4_icon %}
              {% unless section.settings.icon4_icon == blank %}
                {% assign icon_text = section.settings.icon4_icon | strip %}
                {% if icon_text contains "<svg" %}
                  <div
                    data-dm-element="icon"
                    class="w-fit text-primary"
                    style="aspect-ratio: 1/1; color: {{ section.settings.icon4IconColor_color }}; width: var(--{{ section.id }}--icon4IconSize_responsive_range); height: var(--{{ section.id }}--icon4IconSize_responsive_range);">{{ section.settings.icon4_icon }}</div>
                {% else %}
                  <div
                    data-dm-element="icon"
                    class="w-fit text-primary"
                    style="line-height: 100%; font-size: var(--{{ section.id }}--icon4IconSize_responsive_range);">{{ section.settings.icon4_icon }}</div>
                {% endif %}
              {% endunless %}
          {% else %}
            {% endif %}
          </div>

          <h3 class="text-foreground mb-2 {{ section.settings.title4TextStyle_font_mobile }} sm:{{ section.settings.title4TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--title4TextAlign_text_alignment); color: {{ section.settings.title4TextColor_color }};">{{ section.settings.title4_text }}</h3>
          <p class="text-foreground {{ section.settings.description4TextStyle_font_mobile }} sm:{{ section.settings.description4TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--description4TextAlign_text_alignment); color: {{ section.settings.description4TextColor_color }};">{{ section.settings.description4_text }}</p>
        </div>
      </div>
    </div>
  </div>
  {{ section.settings.bottom_mask }}</div>


