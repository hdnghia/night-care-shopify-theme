{% comment %}
  Dropmagic Section | Version: 1.1.2
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
<link
  rel="stylesheet"
  href="{{ 'component-cart-notification.css' | asset_url }}"
  media="print"
  onload="this.media='all'">
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/vanilla-infinite-marquee@1.0.12/infinite-marquee.min.css"
  defer="defer">
<script src="https://cdn.jsdelivr.net/npm/vanilla-infinite-marquee@1.0.12/infinite-marquee.bundle.js" defer="defer"></script>
<script src="{{ 'dm-marquee.js' | asset_url }}" defer="defer"></script>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
  defer="defer" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>
<script src="{{ 'dm-swiper.js' | asset_url }}" defer="defer"></script>


<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ section.id }}--announcementTextTextAlign_text_alignment: {{ section.settings.announcementTextTextAlign_text_alignment_mobile | default: section.settings.announcementTextTextAlign_text_alignment_desktop }};
    --{{ section.id }}--announcementText2TextAlign_text_alignment: {{ section.settings.announcementText2TextAlign_text_alignment_mobile | default: section.settings.announcementText2TextAlign_text_alignment_desktop }};
    --{{ section.id }}--announcementText3TextAlign_text_alignment: {{ section.settings.announcementText3TextAlign_text_alignment_mobile | default: section.settings.announcementText3TextAlign_text_alignment_desktop }};
    --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_mobile | default: section.settings.sectionPaddingTop_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_mobile | default: section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_mobile | default: section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_mobile | default: section.settings.sectionPaddingRight_responsive_range_desktop }}px;
    --{{ section.id }}--logoLogoSize_responsive_range: {{ section.settings.logoLogoSize_responsive_range_mobile | default: section.settings.logoLogoSize_responsive_range_desktop }}px;
    --{{ section.id }}--navMenuTextTextAlign_text_alignment: {{ section.settings.navMenuTextTextAlign_text_alignment_mobile | default: section.settings.navMenuTextTextAlign_text_alignment_desktop }};
    --{{ section.id }}--cartIconIconSize_responsive_range: {{ section.settings.cartIconIconSize_responsive_range_mobile | default: section.settings.cartIconIconSize_responsive_range_desktop }}px;
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ section.id }}--announcementTextTextAlign_text_alignment: {{ section.settings.announcementTextTextAlign_text_alignment_desktop }};
      --{{ section.id }}--announcementText2TextAlign_text_alignment: {{ section.settings.announcementText2TextAlign_text_alignment_desktop }};
      --{{ section.id }}--announcementText3TextAlign_text_alignment: {{ section.settings.announcementText3TextAlign_text_alignment_desktop }};
      --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_desktop }}px;
      --{{ section.id }}--logoLogoSize_responsive_range: {{ section.settings.logoLogoSize_responsive_range_desktop }}px;
      --{{ section.id }}--navMenuTextTextAlign_text_alignment: {{ section.settings.navMenuTextTextAlign_text_alignment_desktop }};
      --{{ section.id }}--cartIconIconSize_responsive_range: {{ section.settings.cartIconIconSize_responsive_range_desktop }}px;
    }
  }
</style>


<div class="sticky -top-[1px] group hover:top-0 transition-all duration-200 z-50" style="position: {{ section.settings.headerSticky_select }};">
  {% if section.settings.announcementType_select != "none" %}
    <div class="py-2  bg-black" style="background-color: {{ section.settings.announcementBackground_color }};">
      {% if section.settings.announcementType_select == "marquee" %}
        <dm-marquee class="" data-speed="{{ section.settings.announcementMarqueeSpeed_range }}">
          <div class="ml-5 flex items-center justify-center">
            <p class="text-foreground {{ section.settings.announcementTextTextStyle_font_mobile }} sm:{{ section.settings.announcementTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--announcementTextTextAlign_text_alignment); color: {{ section.settings.announcementTextTextColor_color }};">{{ section.settings.announcementText_text }}</p>
          </div>
        </dm-marquee>
    {% else %}
      {% endif %}

      {% if section.settings.announcementType_select == "simple" %}
        <p class="text-foreground mx-auto w-fit {{ section.settings.announcementTextTextStyle_font_mobile }} sm:{{ section.settings.announcementTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--announcementTextTextAlign_text_alignment); color: {{ section.settings.announcementTextTextColor_color }};">{{ section.settings.announcementText_text }}</p>
    {% else %}
      {% endif %}

      {% if section.settings.announcementType_select == "swipe" %}
        <dm-swiper
          class="swiper select-none pointer-events-none"
          {% capture swiper_config %}
          {
          "centeredSlides"
          :
          true,
          "navigation"
          :
          false,
          "draggable"
          :
          false,
          "slidesPerView"
          :
          1,
          "pagination"
          :
          {
          "enabled"
          :
          false
          },
          "scrollbar"
          :
          {
          "draggable"
          :
          false,
          "enabled"
          :
          false,
          "hide"
          :
          true
          },
          "autoplay"
          :
          {"delay"
          :
          {{ section.settings.announcementTimer_number }}
          ,"pauseOnMouseEnter"
          :
          true,"disableOnInteraction"
          :
          true,"waitForTransition"
          :
          false},
          "loop"
          :
          true
          }
          {% endcapture %}
          data-config='{{ swiper_config | strip_newlines }}'>
          <div class="swiper-wrapper">

            <div class="swiper-slide">

              <p class="text-foreground w-fit mx-auto {{ section.settings.announcementTextTextStyle_font_mobile }} sm:{{ section.settings.announcementTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--announcementTextTextAlign_text_alignment); color: {{ section.settings.announcementTextTextColor_color }};">{{ section.settings.announcementText_text }}</p>

            </div>

            <div class="swiper-slide">

              <p class="text-foreground w-fit mx-auto {{ section.settings.announcementText2TextStyle_font_mobile }} sm:{{ section.settings.announcementText2TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--announcementText2TextAlign_text_alignment); color: {{ section.settings.announcementText2TextColor_color }};">{{ section.settings.announcementText2_text }}</p>

            </div>

            <div class="swiper-slide">

              <p class="text-foreground w-fit mx-auto {{ section.settings.announcementText3TextStyle_font_mobile }} sm:{{ section.settings.announcementText3TextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--announcementText3TextAlign_text_alignment); color: {{ section.settings.announcementText3TextColor_color }};">{{ section.settings.announcementText3_text }}</p>

            </div>

          </div>
        </dm-swiper>
    {% else %}
      {% endif %}
    </div>
{% else %}
  {% endif %}
  <header class="border-b shadow-sm border-border" style="border-color: {{ section.settings.borderColor_color }};">
    <div
      data-section-combination="{{section.settings.section_combination}}"
      class="block relative w-full transition-colors bg-background "
      style="background: {{ section.settings.sectionBackground_color }}; padding-top: var(--{{ section.id }}--sectionPaddingTop_responsive_range); padding-bottom: var(--{{ section.id }}--sectionPaddingBottom_responsive_range); padding-left: var(--{{ section.id }}--sectionPaddingLeft_responsive_range); padding-right: var(--{{ section.id }}--sectionPaddingRight_responsive_range);">
      <div class="mx-auto flex justify-between items-center min-h-12 " style="max-width: {{ section.settings.sectionMaxWidth_number }}px;">
        <div class="flex items-center gap-x-8">
          <div class="dm-hidden sm:block sm:order-1 order-2 w-fit h-fit leading-none">

            <a style="display:flex;" href="{% if section.settings.logoLink_link == nil %}/#{% else %}{{ section.settings.logoLink_link }}{% endif %}">
              <div class="relative" style="width: auto; display: inline-block; height: var(--{{ section.id }}--logoLogoSize_responsive_range);">
                <img
                  src="{% if section.settings.logo_media == blank %}{{  settings.logo }}{% else %}{{ section.settings.logo_media | image_url }}{% endif %}"
                  alt=" "
                  draggable="false"
                  class=""
                  style="object-fit: contain; height: 100%; width: auto; background-color: transparent;">
              </div>
            </a>

          </div>

          <div class="sm:order-2 order-1">
            <nav>
              <!-- Mobile Menu with Drawer -->
              <div class="flex sm:hidden justify-start">
                <button id="menu-toggle-{{ section.id }}" class="flex items-center justify-center">
                  <span class="svg-wrapper">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      style="width:20px; height:20px"
                      class="icon icon-hamburger"
                      viewBox="0 0 18 16"><path fill="currentColor" d="M1 .5a.5.5 0 1 0 0 1h15.71a.5.5 0 0 0 0-1zM.5 8a.5.5 0 0 1 .5-.5h15.71a.5.5 0 0 1 0 1H1A.5.5 0 0 1 .5 8m0 7a.5.5 0 0 1 .5-.5h15.71a.5.5 0 0 1 0 1H1a.5.5 0 0 1-.5-.5" /></svg>
                  </span>
                </button>

                <!-- Mobile Drawer Container - Contains both overlay and sliding content -->
                <div id="mobile-drawer-container-{{ section.id }}" class="fixed inset-0 z-[1000000] pointer-events-none">
                  <!-- Overlay - No sliding animation, just opacity -->
                  <div id="drawer-overlay-{{ section.id }}" class="fixed inset-0 bg-black/50 opacity-0 transition-opacity duration-300 ease-in-out pointer-events-none">
                    <div><!-- Non-empty to ensure it appears in DOM --></div>
                  </div>

                  <!-- Sliding Content -->
                  <div
                    id="mobile-drawer-{{ section.id }}"
                    class="fixed w-3/4 max-w-sm inset-y-0 z-[1000001] left-0 flex justify-start translate-x-[-100%] transition-transform duration-300 ease-in-out pointer-events-auto"
                    style="height:100vh !important">
                    <div class="relative w-full h-full bg-background shadow-lg z-10">
                      <div class="absolute top-3 right-3">
                        <button id="close-drawer-{{ section.id }}">
                          <span class="svg-wrapper text-black">{{- 'icon-close.svg' | inline_asset_content -}}</span>
                        </button>
                      </div>
                      <div class="flex flex-col gap-y-3 px-2 pt-10">
                        {%- for link in section.settings.menu_menu.links -%}
                          <div class=" p-3 rounded-sm">
                            <a
                              href="{{ link.url }}"
                              {% if link.current %}
                              aria-current="page"
                              {% endif %}
                              class="content-md-bold">
                              <p class="text-foreground {{ section.settings.navMenuTextTextStyle_font_mobile }} sm:{{ section.settings.navMenuTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--navMenuTextTextAlign_text_alignment); color: {{ section.settings.navMenuTextTextColor_color }};">{{ link.title | escape }}</p>
                            </a>
                          </div>
                        {%- endfor -%}
                      </div>
                    </div>
                  </div>
                </div>

                <script>
                  (function() {
                    document.addEventListener('DOMContentLoaded', function() {
                      var sectionId = {{ section.id | json }};
                      var menuToggle = document.getElementById('menu-toggle-' + sectionId);
                      var closeDrawer = document.getElementById('close-drawer-' + sectionId);
                      var drawerContainer = document.getElementById('mobile-drawer-container-' + sectionId);
                      var drawer = document.getElementById('mobile-drawer-' + sectionId);
                      var overlay = document.getElementById('drawer-overlay-' + sectionId);

                      if (! menuToggle || ! closeDrawer || ! drawerContainer || ! drawer || ! overlay) 
                        return;
                      

                      function openDrawer() {
                        drawerContainer.style.pointerEvents = 'auto';
                        drawer.style.transform = 'translateX(0)';
                        overlay.style.opacity = '1';
                        overlay.style.pointerEvents = 'auto';
                      }

                      function closeDrawerFunc() {
                        drawer.style.transform = 'translateX(-100%)';
                        overlay.style.opacity = '0';

// Delay disabling pointer events until transition completes
                        setTimeout(function() {
                          if (drawer.style.transform === 'translateX(-100%)') {
                            drawerContainer.style.pointerEvents = 'none';
                            overlay.style.pointerEvents = 'none';
                          }
                        }, 300);
                      }

                      menuToggle.addEventListener('click', openDrawer);
                      closeDrawer.addEventListener('click', closeDrawerFunc);
                      overlay.addEventListener('click', closeDrawerFunc);
                    });
                  })();
                </script>
              </div>

              <!-- Desktop Menu -->
              <ul class="dm-hidden sm:flex  items-center gap-x-6 flex flex-row" role="list">
                {%- for link in section.settings.menu_menu.links -%}
                  <li>
                    <a
                      id="{{ link.handle }}"
                      href="{{ link.url }}"
                      class="hover:underline"
                      {% if link.current %}
                      aria-current="page"
                      {% endif %}>
                      <span
                        {%- if link.current %}
                        class="underline"
                        {% endif %}>
                        <p class="text-foreground {{ section.settings.navMenuTextTextStyle_font_mobile }} sm:{{ section.settings.navMenuTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--navMenuTextTextAlign_text_alignment); color: {{ section.settings.navMenuTextTextColor_color }};">{{ link.title | escape }}</p>
                      </span>
                    </a>
                  </li>
                {%- endfor -%}
              </ul>

            </nav>
          </div>
        </div>
        <div class="dm-block sm:hidden leading-none">

          <a style="display:flex;" href="{% if section.settings.logoLink_link == nil %}/#{% else %}{{ section.settings.logoLink_link }}{% endif %}">
            <div class="relative" style="width: auto; display: inline-block; height: var(--{{ section.id }}--logoLogoSize_responsive_range);">
              <img
                src="{% if section.settings.logo_media == blank %}{{  settings.logo }}{% else %}{{ section.settings.logo_media | image_url }}{% endif %}"
                alt=" "
                draggable="false"
                class=""
                style="object-fit: contain; height: 100%; width: auto; background-color: transparent;">
            </div>
          </a>

        </div>
        <div class="flex items-center gap-x-4 md:gap-x-8">


          <a
            href="{{ routes.cart_url }}"
            id="cart-icon-button"
            class="relative">

            {% unless section.settings.cartIcon_icon == blank %}
              {% assign icon_text = section.settings.cartIcon_icon | strip %}
              {% if icon_text contains "<svg" %}
                <div
                  data-dm-element="icon"
                  class="w-fit text-foreground"
                  style="aspect-ratio: 1/1; color: {{ section.settings.cartIconIconColor_color }}; width: var(--{{ section.id }}--cartIconIconSize_responsive_range); height: var(--{{ section.id }}--cartIconIconSize_responsive_range);">{{ section.settings.cartIcon_icon }}</div>
              {% else %}
                <div
                  data-dm-element="icon"
                  class="w-fit text-foreground"
                  style="line-height: 100%; font-size: var(--{{ section.id }}--cartIconIconSize_responsive_range);">{{ section.settings.cartIcon_icon }}</div>
              {% endif %}
            {% endunless %}

            <div class="dm-cart-count-bubble" id="dm-cart-count-bubble">
              <div style="visibility: {%- if cart == empty -%}hidden{%- else -%}visible{%- endif -%};">
                {%- if cart.item_count < 100 -%}
                  <span aria-hidden="true">{{ cart.item_count }}</span>
                {%- endif -%}
              </div>
            </div>
          </a>
        </div>
      </div>
      {{ section.settings.bottom_mask }}</div>
  </header>
</div>


{%- if settings.cart_type == "notification" -%}
  {%- render 'cart-notification' -%}
{%- endif -%}

{% schema %}
  {
    "name": "Header",
    "tag": "section",
    "class": "dm-section",
    "disabled_on": {
      "groups": ["footer"]
    },
    "settings": [
      {
        "type": "header",
        "content": "Section"
      },
      {
        "type": "color_background",
        "id": "sectionBackground_color",
        "label": "Background"
      },
      {
        "type": "number",
        "id": "sectionPaddingTop_responsive_range_desktop",
        "label": "Padding top (Desktop)",
        "default": 56
      },
      {
        "type": "number",
        "id": "sectionPaddingTop_responsive_range_mobile",
        "label": "Padding top (Mobile)",
        "default": 56
      }, {
        "type": "number",
        "id": "sectionPaddingBottom_responsive_range_desktop",
        "label": "Padding bottom (Desktop)",
        "default": 56
      }, {
        "type": "number",
        "id": "sectionPaddingBottom_responsive_range_mobile",
        "label": "Padding bottom (Mobile)",
        "default": 56
      }, {
        "type": "number",
        "id": "sectionPaddingLeft_responsive_range_desktop",
        "label": "Padding left (Desktop)",
        "default": 64
      }, {
        "type": "number",
        "id": "sectionPaddingLeft_responsive_range_mobile",
        "label": "Padding left (Mobile)",
        "default": 64
      }, {
        "type": "number",
        "id": "sectionPaddingRight_responsive_range_desktop",
        "label": "Padding right (Desktop)",
        "default": 64
      }, {
        "type": "number",
        "id": "sectionPaddingRight_responsive_range_mobile",
        "label": "Padding right (Mobile)",
        "default": 64
      }, {
        "type": "number",
        "id": "sectionMaxWidth_number",
        "label": "Max width",
        "default": 1400
      }, {
        "type": "header",
        "content": "Section Mask"
      }, {
        "type": "liquid",
        "id": "bottom_mask",
        "label": "Bottom Mask"
      }, {
        "type": "select",
        "id": "section_combination",
        "label": "Section combination",
        "default": "light",
        "options": [
          {
            "label": "White",
            "value": "white"
          },
          {
            "label": "Light",
            "value": "light"
          },
          {
            "label": "Neutral",
            "value": "neutral"
          },
          {
            "label": "Tinted",
            "value": "tinted"
          }, {
            "label": "Tinted secondary",
            "value": "tinted-secondary"
          }, {
            "label": "Tinted tertiary",
            "value": "tinted-tertiary"
          }, {
            "label": "Vibrant",
            "value": "vibrant"
          }, {
            "label": "Gradient",
            "value": "gradient"
          }, {
            "label": "Dark",
            "value": "dark"
          }
