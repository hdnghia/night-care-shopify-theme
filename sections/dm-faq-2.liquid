<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_mobile | default: section.settings.sectionPaddingTop_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_mobile | default: section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_mobile | default: section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_mobile | default: section.settings.sectionPaddingRight_responsive_range_desktop }}px;
    --{{ section.id }}--titleTextAlign_text_alignment: {{ section.settings.titleTextAlign_text_alignment_mobile | default: section.settings.titleTextAlign_text_alignment_desktop }};
    --{{ section.id }}--subtitleTextAlign_text_alignment: {{ section.settings.subtitleTextAlign_text_alignment_mobile | default: section.settings.subtitleTextAlign_text_alignment_desktop }};
    --{{ section.id }}--footerTitleTextAlign_text_alignment: {{ section.settings.footerTitleTextAlign_text_alignment_mobile | default: section.settings.footerTitleTextAlign_text_alignment_desktop }};
    --{{ section.id }}--footerDescriptionTextAlign_text_alignment: {{ section.settings.footerDescriptionTextAlign_text_alignment_mobile | default: section.settings.footerDescriptionTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_desktop }}px;
      --{{ section.id }}--titleTextAlign_text_alignment: {{ section.settings.titleTextAlign_text_alignment_desktop }};
      --{{ section.id }}--subtitleTextAlign_text_alignment: {{ section.settings.subtitleTextAlign_text_alignment_desktop }};
      --{{ section.id }}--footerTitleTextAlign_text_alignment: {{ section.settings.footerTitleTextAlign_text_alignment_desktop }};
      --{{ section.id }}--footerDescriptionTextAlign_text_alignment: {{ section.settings.footerDescriptionTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div
  data-section-combination="{{section.settings.section_combination}}"
  class="block relative w-full transition-colors bg-background "
  style="background: {{ section.settings.sectionBackground_color }}; padding-top: var(--{{ section.id }}--sectionPaddingTop_responsive_range); padding-bottom: var(--{{ section.id }}--sectionPaddingBottom_responsive_range); padding-left: var(--{{ section.id }}--sectionPaddingLeft_responsive_range); padding-right: var(--{{ section.id }}--sectionPaddingRight_responsive_range);">
  <div class="mx-auto " style="max-width: {{ section.settings.sectionMaxWidth_number }}px;">
    <div class="flex flex-col gap-6 gap-y-6 md:gap-y-12 ">
      <div class="flex flex-col gap-6 gap-y-2 ">
        <h2 class="text-foreground {{ section.settings.titleTextStyle_font_mobile }} sm:{{ section.settings.titleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--titleTextAlign_text_alignment); color: {{ section.settings.titleTextColor_color }};">{{ section.settings.title_text }}</h2>
        <p class="text-muted-foreground {{ section.settings.subtitleTextStyle_font_mobile }} sm:{{ section.settings.subtitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--subtitleTextAlign_text_alignment); color: {{ section.settings.subtitleTextColor_color }};">{{ section.settings.subtitle_text }}</p>
      </div>

      <div class="grid w-full grid-cols-1 items-start gap-x-6 gap-y-3 md:grid-cols-2 ">
        {%- for block in section.blocks -%}

          {%- case block.type -%}
            {%- when '@app' -%}
            {% render block %}
            {%- when 'dm-faq-1-block' -%}
            {% render 'dm-faq-1-block' block: block, accordionRotateIcon_checkbox: block.settings.accordionRotateIcon_checkbox, accordionStyle_select: block.settings.accordionStyle_select, accordionSize_select: block.settings.accordionSize_select, accordionAccordionBackground_color: block.settings.accordionAccordionBackground_color, accordionAccordionBorder_color: block.settings.accordionAccordionBorder_color, accordionAccordionRadius_number: block.settings.accordionAccordionRadius_number, accordionAccordionBorder_number: block.settings.accordionAccordionBorder_number, accordionTitle_text: block.settings.accordionTitle_text, accordionTitleTextColor_color: block.settings.accordionTitleTextColor_color, accordionTitleTextStyle_font_desktop: block.settings.accordionTitleTextStyle_font_desktop, accordionTitleTextStyle_font_mobile: block.settings.accordionTitleTextStyle_font_mobile, accordionTitleTextAlign_text_alignment_desktop: block.settings.accordionTitleTextAlign_text_alignment_desktop, accordionTitleTextAlign_text_alignment_mobile: block.settings.accordionTitleTextAlign_text_alignment_mobile, accordionContent_text: block.settings.accordionContent_text, accordionContentTextColor_color: block.settings.accordionContentTextColor_color, accordionContentTextStyle_font_desktop: block.settings.accordionContentTextStyle_font_desktop, accordionContentTextStyle_font_mobile: block.settings.accordionContentTextStyle_font_mobile, accordionContentTextAlign_text_alignment_desktop: block.settings.accordionContentTextAlign_text_alignment_desktop, accordionContentTextAlign_text_alignment_mobile: block.settings.accordionContentTextAlign_text_alignment_mobile, accordionIcon_icon: block.settings.accordionIcon_icon, accordionIconIconColor_color: block.settings.accordionIconIconColor_color, accordionIconIconSize_responsive_range_desktop: block.settings.accordionIconIconSize_responsive_range_desktop, accordionIconIconSize_responsive_range_mobile: block.settings.accordionIconIconSize_responsive_range_mobile %}{%- endcase -%}
        {%- endfor -%}
      </div>

      <div class="flex flex-col gap-6 gap-y-2 ">
        <h3 class="text-foreground {{ section.settings.footerTitleTextStyle_font_mobile }} sm:{{ section.settings.footerTitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--footerTitleTextAlign_text_alignment); color: {{ section.settings.footerTitleTextColor_color }};">{{ section.settings.footerTitle_text }}</h3>
        <p class="text-muted-foreground {{ section.settings.footerDescriptionTextStyle_font_mobile }} sm:{{ section.settings.footerDescriptionTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--footerDescriptionTextAlign_text_alignment); color: {{ section.settings.footerDescriptionTextColor_color }};">{{ section.settings.footerDescription_text }}</p>
      </div>
    </div>
  </div>
  {{ section.settings.bottom_mask }}</div>


