{% comment %}
  Dropmagic Section | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}


<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_mobile | default: section.settings.sectionPaddingTop_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_mobile | default: section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_mobile | default: section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_mobile | default: section.settings.sectionPaddingRight_responsive_range_desktop }}px;
    --{{ section.id }}--imageHeight_responsive_range: {{ section.settings.imageHeight_responsive_range_mobile | default: section.settings.imageHeight_responsive_range_desktop }}px;
    --{{ section.id }}--imageImageAspectRatio_responsive_select: {{ section.settings.imageImageAspectRatio_responsive_select_mobile | default: section.settings.imageImageAspectRatio_responsive_select_desktop }};
    --{{ section.id }}--titleTextAlign_text_alignment: {{ section.settings.titleTextAlign_text_alignment_mobile | default: section.settings.titleTextAlign_text_alignment_desktop }};
    --{{ section.id }}--descriptionTextAlign_text_alignment: {{ section.settings.descriptionTextAlign_text_alignment_mobile | default: section.settings.descriptionTextAlign_text_alignment_desktop }};
    --{{ section.id }}--buttonTextTextAlign_text_alignment: {{ section.settings.buttonTextTextAlign_text_alignment_mobile | default: section.settings.buttonTextTextAlign_text_alignment_desktop }};
    --{{ section.id }}--buttonIconIconSize_responsive_range: {{ section.settings.buttonIconIconSize_responsive_range_mobile | default: section.settings.buttonIconIconSize_responsive_range_desktop }}px;
    --{{ section.id }}--buttonSubtitleTextAlign_text_alignment: {{ section.settings.buttonSubtitleTextAlign_text_alignment_mobile | default: section.settings.buttonSubtitleTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_desktop }}px;
      --{{ section.id }}--imageHeight_responsive_range: {{ section.settings.imageHeight_responsive_range_desktop }}px;
      --{{ section.id }}--imageImageAspectRatio_responsive_select: {{ section.settings.imageImageAspectRatio_responsive_select_desktop }};
      --{{ section.id }}--titleTextAlign_text_alignment: {{ section.settings.titleTextAlign_text_alignment_desktop }};
      --{{ section.id }}--descriptionTextAlign_text_alignment: {{ section.settings.descriptionTextAlign_text_alignment_desktop }};
      --{{ section.id }}--buttonTextTextAlign_text_alignment: {{ section.settings.buttonTextTextAlign_text_alignment_desktop }};
      --{{ section.id }}--buttonIconIconSize_responsive_range: {{ section.settings.buttonIconIconSize_responsive_range_desktop }}px;
      --{{ section.id }}--buttonSubtitleTextAlign_text_alignment: {{ section.settings.buttonSubtitleTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div
  data-section-combination="{{section.settings.section_combination}}"
  class="block relative w-full transition-colors bg-background "
  style="background: {{ section.settings.sectionBackground_color }}; padding-top: var(--{{ section.id }}--sectionPaddingTop_responsive_range); padding-bottom: var(--{{ section.id }}--sectionPaddingBottom_responsive_range); padding-left: var(--{{ section.id }}--sectionPaddingLeft_responsive_range); padding-right: var(--{{ section.id }}--sectionPaddingRight_responsive_range);">
  <div class="mx-auto " style="max-width: {{ section.settings.sectionMaxWidth_number }}px;">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-20 items-center gap-y-4 ">
      <div class="relative w-full h-full order-1 {% if section.settings.imageOnRight_checkbox %}md:order-2{% else %}{% endif %}">

        {% unless section.settings.imageImageHide_responsive_checkbox_mobile and section.settings.imageImageHide_responsive_checkbox_desktop %}

          {% assign media_style_value = settings.media_style %}
          {% if section.settings.imageImageStyle_select != blank %}
            {% assign media_style_value = section.settings.imageImageStyle_select %}
          {% endif %}
          {% if section.settings.imageImageMask_media_mask != blank %}
            {% assign media_style_value = "none" %}
          {% endif %}


          {%- capture media_classes -%}
            {% render 'dm_classname_utils'
             , type: "media",
             media_style: media_style_value %}
          {%- endcapture -%}

          {% if section.settings.imageImageMask_media_mask != blank %}
            {% assign id_part = section.settings.imageImageMask_media_mask | split: 'id="' | last | split: '"' | first %}
            <svg
              width="0"
              height="0"
              style="position: absolute;">
              <defs>{{ section.settings.imageImageMask_media_mask }}</defs>
            </svg>
          {% endif %}

          {% liquid
    if imageHeight_responsive_range_mobile != blank
      assign mobile_width = 'w-auto'
    else
      assign mobile_width = 'w-full'
    endif

    if imageHeight_responsive_range_desktop != blank
      assign desktop_width = 'sm:w-auto'
    else
      assign desktop_width = 'sm:w-full'
    endif

    assign width_classes = mobile_width | append: ' ' | append: desktop_width
  %}

          {% if section.settings.image_media != blank or section.settings.image_media_video != blank %}
            <div class="relative max-w-full  {% if section.settings.imageImageHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif section.settings.imageImageHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}" style="aspect-ratio: var(--{{ section.id }}--imageImageAspectRatio_responsive_select); height: var(--{{ section.id }}--imageHeight_responsive_range);">

              {% assign video_extensions = '.mp4,.webm,.mov,.avi,.avif,.m4v' | split: ',' %}
              {% assign is_valid_video = false %}
              {% for ext in video_extensions %}
                {% if section.settings.image_media_video contains ext %}
                  {% assign is_valid_video = true %}
                  {% break %}
                {% endif %}
              {% endfor %}

              {% if section.settings.image_media_video != blank and is_valid_video %}
                {% assign video_url = section.settings.image_media_video | split: '?' | first %}
                {% assign video_params = section.settings.image_media_video | split: '?' | last | split: '&' %}
                {% assign video_attrs = '' %}
                {% for param in video_params %}
                  {% assign key_value = param | split: '=' %}
                  {% assign key = key_value | first | downcase %}
                  {% assign value = key_value | last %}
                  {% case key %}
                    {% when 'loop' %}
                    {% assign video_attrs = video_attrs | append: ' loop' %}
                    {% when 'autoplay' %}
                    {% assign video_attrs = video_attrs | append: ' autoplay' %}
                    {% when 'muted' %}
                    {% assign video_attrs = video_attrs | append: ' muted' %}
                    {% when 'controls' %}
                    {% assign video_attrs = video_attrs | append: ' controls' %}
                    {% when 'playsinline' %}
                    {% assign video_attrs = video_attrs | append: ' playsinline' %}
                  {% endcase %}
                {% endfor %}
                <video
                  src="{{ video_url }}"
                  {% if section.settings.image_media != blank %}poster="{{ section.settings.image_media | image_url }}"{% endif %}
                  alt=" "
                  preload="metadata"
                  draggable="false"
                  class="border-solid h-full object-cover {{ media_classes | strip }} {{ width_classes }}"
                  style="{% if id_part != blank %}clip-path: url(#{{id_part}}); -webkit-clip-path: url(#{{id_part}});{% endif %} {% if section.settings.imageImageBorder_number != blank %} border-width: {{ section.settings.imageImageBorder_number }}px;{% endif %} {% if section.settings.imageImageBorder_color != blank %} border-color:{{ section.settings.imageImageBorder_color }};{% endif %} {% if section.settings.imageImageRadius_number != blank %} border-radius: {{ section.settings.imageImageRadius_number }}px;{% endif %} {% if section.settings.imageImagePosition_select != blank %} object-position: {{ section.settings.imageImagePosition_select }};{% endif %}"
                  {{ video_attrs }}></video>
              {% else %}
                <img
                  src="{{ section.settings.image_media | image_url }}"
                  alt=" "
                  draggable="false"
                  loading="lazy"
                  class="border-solid h-full object-cover {{ media_classes | strip }} {{ width_classes }}"
                  style="{% if id_part != blank %}clip-path: url(#{{id_part}}); -webkit-clip-path: url(#{{id_part}});{% endif %} {% if section.settings.imageImageBorder_number != blank %} border-width: {{ section.settings.imageImageBorder_number }}px;{% endif %} {% if section.settings.imageImageBorder_color != blank %} border-color:{{ section.settings.imageImageBorder_color }};{% endif %} {% if section.settings.imageImageRadius_number != blank %} border-radius: {{ section.settings.imageImageRadius_number }}px;{% endif %} {% if section.settings.imageImagePosition_select != blank %} object-position: {{ section.settings.imageImagePosition_select }};{% endif %}">
              {% endif %}
            </div>
          {% else %}
            <div class="relative max-w-full  {{ media_align_class }} {% if section.settings.imageImageHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif section.settings.imageImageHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}" style="aspect-ratio: var(--{{ section.id }}--imageImageAspectRatio_responsive_select);">
              {{ 'image' | placeholder_svg_tag: width_classes | strip }}
            </div>
          {% endif %}
        {% endunless %}

      </div>
      <div class="flex flex-col justify-center items-start gap-4 md:gap-8 order-2 {% if section.settings.imageOnRight_checkbox %}md:order-1{% else %}{% endif %}">
        <div class="flex flex-col gap-4 items-start">
          <h2 class="text-foreground w-full {{ section.settings.titleTextStyle_font_mobile }} sm:{{ section.settings.titleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--titleTextAlign_text_alignment); color: {{ section.settings.titleTextColor_color }};">{{ section.settings.title_text }}</h2>
          <p class="text-muted-foreground {{ section.settings.descriptionTextStyle_font_mobile }} sm:{{ section.settings.descriptionTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--descriptionTextAlign_text_alignment); color: {{ section.settings.descriptionTextColor_color }};">{{ section.settings.description_text }}</p>
        </div>
        <div class="w-full flex flex-col gap-2 items-center">


          {%- capture button_classes -%}
            {% render 'dm_classname_utils'
             , type: "button",
             button_style: settings.button_style,
             button_variant: section.settings.buttonButtonVariant_select,
             button_size: section.settings.buttonButtonSize_select,
             button_width: "full" %}
          {%- endcapture -%}

          {% if section.settings.buttonButtonLink_link == "#add-to-cart" or section.settings.buttonButtonLink_link == nil %}
            {% if product != nil %}
              <!-- If add to cart we render the form -->
              <dm-product-form class="w-full">
                {%- unless product_form_id -%}
                  {% assign product_form_id = 'product-form-dm-image-text' | append: section.id %}
                {%- endunless -%}
                {%- form 'product',
 product,
 id: product_form_id,
 class: 'form',
 novalidate: 'novalidate',
 data-type: 'add-to-cart-form'
 -%}
                  <input
                    type="hidden"
                    name="id"
                    class="product-variant-id"
                    value="{{ product.selected_or_first_available_variant.id }}"
                    {% if section.settings.skip_cart %}data-skip-cart="true"{% endif %}>
                  <div class="product-form__buttons flex flex-col gap-2 w-full">
                    {%- unless section.settings.buttonShowOnlyDynamicCheckout_checkbox -%}
                      <button
                        name="add"
                        type="submit"
                        data-button-variant="{{ section.settings.buttonButtonVariant_select }}"
                        data-button-style="{{ settings.button_style }}"
                        data-button-size="{{ section.settings.buttonButtonSize_select }}"
                        data-button-width="full"
                        style="{% if section.settings.buttonButtonRadius_number != nil %}border-radius: {{ section.settings.buttonButtonRadius_number }}px;{% endif %}"
                        class="gap-2.5 group rounded-md  text-center inline-flex items-center justify-center transition-all duration-150 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 {{ button_classes | strip }} {% if section.settings.buttonHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif section.settings.buttonHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %} ">

                        <p class="text-inherit {{ section.settings.buttonTextTextStyle_font_mobile }} sm:{{ section.settings.buttonTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--buttonTextTextAlign_text_alignment); color: {{ section.settings.buttonTextTextColor_color }};">{{ section.settings.buttonText_text }}</p>
                        {% if section.settings.buttonIcon_icon %}
                          {% unless section.settings.buttonIcon_icon == blank %}
                            {% assign icon_text = section.settings.buttonIcon_icon | strip %}
                            {% if icon_text contains "<svg" %}
                              <div
                                data-dm-element="icon"
                                class="w-fit translate-x-0 group-hover:translate-x-1 transition-transform text-inherit"
                                style="aspect-ratio: 1/1; color: {{ section.settings.buttonIconIconColor_color }}; width: var(--{{ section.id }}--buttonIconIconSize_responsive_range); height: var(--{{ section.id }}--buttonIconIconSize_responsive_range);">{{ section.settings.buttonIcon_icon }}</div>
                            {% else %}
                              <div
                                data-dm-element="icon"
                                class="w-fit translate-x-0 group-hover:translate-x-1 transition-transform text-inherit"
                                style="line-height: 100%; font-size: var(--{{ section.id }}--buttonIconIconSize_responsive_range);">{{ section.settings.buttonIcon_icon }}</div>
                            {% endif %}
                          {% endunless %}
                      {% else %}
                        {% endif %}

                      </button>
                    {%- endunless -%}
                    {%- if section.settings.buttonShowDynamicCheckout_checkbox or section.settings.buttonShowOnlyDynamicCheckout_checkbox -%}
                      {{ form | payment_button }}
                    {%- endif -%}
                  </div>
                {%- endform -%}
              </dm-product-form>
            {% else %}
              <!-- No product available, render as a regular button -->
              {% unless section.settings.buttonHide_responsive_checkbox_mobile and section.settings.buttonHide_responsive_checkbox_desktop %}
                <a
                  class="gap-2.5 group rounded-md  text-center inline-flex items-center justify-center transition-all duration-150 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 {{ button_classes | strip }} {% if section.settings.buttonHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif section.settings.buttonHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}"
                  href="#"
                  data-button-variant="{{ section.settings.buttonButtonVariant_select }}"
                  data-button-style="{{ settings.button_style }}"
                  data-button-size="{{ section.settings.buttonButtonSize_select }}"
                  data-button-width="full"
                  style="{% if section.settings.buttonButtonRadius_number != nil %}border-radius: {{ section.settings.buttonButtonRadius_number }}px;{% endif %}">

                  <p class="text-inherit {{ section.settings.buttonTextTextStyle_font_mobile }} sm:{{ section.settings.buttonTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--buttonTextTextAlign_text_alignment); color: {{ section.settings.buttonTextTextColor_color }};">{{ section.settings.buttonText_text }}</p>
                  {% if section.settings.buttonIcon_icon %}
                    {% unless section.settings.buttonIcon_icon == blank %}
                      {% assign icon_text = section.settings.buttonIcon_icon | strip %}
                      {% if icon_text contains "<svg" %}
                        <div
                          data-dm-element="icon"
                          class="w-fit translate-x-0 group-hover:translate-x-1 transition-transform text-inherit"
                          style="aspect-ratio: 1/1; color: {{ section.settings.buttonIconIconColor_color }}; width: var(--{{ section.id }}--buttonIconIconSize_responsive_range); height: var(--{{ section.id }}--buttonIconIconSize_responsive_range);">{{ section.settings.buttonIcon_icon }}</div>
                      {% else %}
                        <div
                          data-dm-element="icon"
                          class="w-fit translate-x-0 group-hover:translate-x-1 transition-transform text-inherit"
                          style="line-height: 100%; font-size: var(--{{ section.id }}--buttonIconIconSize_responsive_range);">{{ section.settings.buttonIcon_icon }}</div>
                      {% endif %}
                    {% endunless %}
                {% else %}
                  {% endif %}

                </a>
              {% endunless %}
            {% endif %}

          {% else %}
            {% unless section.settings.buttonHide_responsive_checkbox_mobile and section.settings.buttonHide_responsive_checkbox_desktop %}
              <!-- If link we put an <a> tag -->
              <a
                class="gap-2.5 group rounded-md  text-center inline-flex items-center justify-center transition-all duration-150 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 {{ button_classes | strip }} {% if section.settings.buttonHide_responsive_checkbox_mobile %}dm-hidden sm:flex{% elsif section.settings.buttonHide_responsive_checkbox_desktop %}sm:dm-hidden{% endif %}"
                href="{% if section.settings.buttonButtonLink_link == "#scroll-to-product" %}#product-hero-section{% else %}{{ section.settings.buttonButtonLink_link }}{% endif %}"
                data-button-variant="{{ section.settings.buttonButtonVariant_select }}"
                data-button-style="{{ settings.button_style }}"
                data-button-size="{{ section.settings.buttonButtonSize_select }}"
                data-button-width="full"
                style="{% if section.settings.buttonButtonRadius_number != nil %}border-radius: {{ section.settings.buttonButtonRadius_number }}px;{% endif %}">

                <p class="text-inherit {{ section.settings.buttonTextTextStyle_font_mobile }} sm:{{ section.settings.buttonTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--buttonTextTextAlign_text_alignment); color: {{ section.settings.buttonTextTextColor_color }};">{{ section.settings.buttonText_text }}</p>
                {% if section.settings.buttonIcon_icon %}
                  {% unless section.settings.buttonIcon_icon == blank %}
                    {% assign icon_text = section.settings.buttonIcon_icon | strip %}
                    {% if icon_text contains "<svg" %}
                      <div
                        data-dm-element="icon"
                        class="w-fit translate-x-0 group-hover:translate-x-1 transition-transform text-inherit"
                        style="aspect-ratio: 1/1; color: {{ section.settings.buttonIconIconColor_color }}; width: var(--{{ section.id }}--buttonIconIconSize_responsive_range); height: var(--{{ section.id }}--buttonIconIconSize_responsive_range);">{{ section.settings.buttonIcon_icon }}</div>
                    {% else %}
                      <div
                        data-dm-element="icon"
                        class="w-fit translate-x-0 group-hover:translate-x-1 transition-transform text-inherit"
                        style="line-height: 100%; font-size: var(--{{ section.id }}--buttonIconIconSize_responsive_range);">{{ section.settings.buttonIcon_icon }}</div>
                    {% endif %}
                  {% endunless %}
              {% else %}
                {% endif %}

              </a>
            {% endunless %}
          {% endif %}

          <p class="text-center w-full text-foreground {{ section.settings.buttonSubtitleTextStyle_font_mobile }} sm:{{ section.settings.buttonSubtitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--buttonSubtitleTextAlign_text_alignment); color: {{ section.settings.buttonSubtitleTextColor_color }};">{{ section.settings.buttonSubtitle_text }}</p>
        </div>
      </div>
    </div>
  </div>
  {{ section.settings.bottom_mask }}</div>


{% schema %}
  {
    "name": "Image Text Button",
    "tag": "section",
    "class": "dm-section",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "settings": [
      {
        "type": "header",
        "content": "Section"
      },
      {
        "type": "color_background",
        "id": "sectionBackground_color",
        "label": "Background"
      },
      {
        "type": "number",
        "id": "sectionPaddingTop_responsive_range_desktop",
        "label": "Padding top (Desktop)",
        "default": 56
      },
      {
        "type": "number",
        "id": "sectionPaddingTop_responsive_range_mobile",
        "label": "Padding top (Mobile)",
        "default": 56
      }, {
        "type": "number",
        "id": "sectionPaddingBottom_responsive_range_desktop",
        "label": "Padding bottom (Desktop)",
        "default": 56
      }, {
        "type": "number",
        "id": "sectionPaddingBottom_responsive_range_mobile",
        "label": "Padding bottom (Mobile)",
        "default": 56
      }, {
        "type": "number",
        "id": "sectionPaddingLeft_responsive_range_desktop",
        "label": "Padding left (Desktop)",
        "default": 64
      }, {
        "type": "number",
        "id": "sectionPaddingLeft_responsive_range_mobile",
        "label": "Padding left (Mobile)",
        "default": 64
      }, {
        "type": "number",
        "id": "sectionPaddingRight_responsive_range_desktop",
        "label": "Padding right (Desktop)",
        "default": 64
      }, {
        "type": "number",
        "id": "sectionPaddingRight_responsive_range_mobile",
        "label": "Padding right (Mobile)",
        "default": 64
      }, {
        "type": "number",
        "id": "sectionMaxWidth_number",
        "label": "Max width",
        "default": 1400
      }, {
        "type": "header",
        "content": "Section Mask"
      }, {
        "type": "liquid",
        "id": "bottom_mask",
        "label": "Bottom Mask"
      }, {
        "type": "select",
        "id": "section_combination",
        "label": "Section combination",
        "default": "light",
        "options": [
          {
            "label": "White",
            "value": "white"
          },
          {
            "label": "Light",
            "value": "light"
          },
          {
            "label": "Neutral",
            "value": "neutral"
          },
          {
            "label": "Tinted",
            "value": "tinted"
          }, {
            "label": "Tinted secondary",
            "value": "tinted-secondary"
          }, {
            "label": "Tinted tertiary",
            "value": "tinted-tertiary"
          }, {
            "label": "Vibrant",
            "value": "vibrant"
          }, {
            "label": "Gradient",
            "value": "gradient"
          }, {
            "label": "Dark",
            "value": "dark"
          }
        ]
      }, {
        "type": "checkbox",
        "id": "imageOnRight_checkbox",
        "label": "Image on right"
      }, {
        "type": "header",
        "content": "Title"
      }, {
        "type": "text",
        "id": "title_text",
        "label": "Text",
        "default": "Lorem ipsum."
      }, {
        "type": "color_background",
        "id": "titleTextColor_color",
        "label": "Text color"
      }, {
        "type": "text",
        "id": "titleTextStyle_font_desktop",
        "label": "Text style (Desktop)",
        "default": "title-md-bold",
        "info": "Get the font key [here](https://app.dropmagic.ai/font-size)"
      }, {
        "type": "text",
        "id": "titleTextStyle_font_mobile",
        "label": "Text style (Mobile)",
        "default": "title-md-bold",
        "info": "Get the font key [here](https://app.dropmagic.ai/font-size)"
      }, {
        "type": "text_alignment",
        "id": "titleTextAlign_text_alignment_desktop",
        "label": "Text align (Desktop)",
        "default": "left"
      }, {
        "type": "text_alignment",
        "id": "titleTextAlign_text_alignment_mobile",
        "label": "Text align (Mobile)",
        "default": "left"
      }, {
        "type": "header",
        "content": "Description"
      }, {
        "type": "text",
        "id": "description_text",
        "label": "Text",
        "default": "Lorem ipsum."
      }, {
        "type": "color_background",
        "id": "descriptionTextColor_color",
        "label": "Text color"
      }, {
        "type": "text",
        "id": "descriptionTextStyle_font_desktop",
        "label": "Text style (Desktop)",
        "default": "content-md-regular",
        "info": "Get the font key [here](https://app.dropmagic.ai/font-size)"
      }, {
        "type": "text",
        "id": "descriptionTextStyle_font_mobile",
        "label": "Text style (Mobile)",
        "default": "content-md-regular",
        "info": "Get the font key [here](https://app.dropmagic.ai/font-size)"
      }, {
        "type": "text_alignment",
        "id": "descriptionTextAlign_text_alignment_desktop",
        "label": "Text align (Desktop)",
        "default": "left"
      }, {
        "type": "text_alignment",
        "id": "descriptionTextAlign_text_alignment_mobile",
        "label": "Text align (Mobile)",
        "default": "left"
      }, {
        "type": "header",
        "content": "Button Subtitle"
      }, {
        "type": "text",
        "id": "buttonSubtitle_text",
        "label": "Text",
        "default": "Lorem ipsum."
      }, {
        "type": "color_background",
        "id": "buttonSubtitleTextColor_color",
        "label": "Text color"
      }, {
        "type": "text",
        "id": "buttonSubtitleTextStyle_font_desktop",
        "label": "Text style (Desktop)",
        "default": "content-md-regular",
        "info": "Get the font key [here](https://app.dropmagic.ai/font-size)"
      }, {
        "type": "text",
        "id": "buttonSubtitleTextStyle_font_mobile",
        "label": "Text style (Mobile)",
        "default": "content-md-regular",
        "info": "Get the font key [here](https://app.dropmagic.ai/font-size)"
      }, {
        "type": "text_alignment",
