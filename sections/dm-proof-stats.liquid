{% liquid
  assign stats_count = 0
  assign reviews_count = 0
  for block in section.blocks
    if block.type == 'stat'
      assign stats_count = stats_count | plus: 1
    endif
    if block.type == 'rating_review'
      assign reviews_count = reviews_count | plus: 1
    endif
  endfor
  assign reviews_initial = section.settings.reviews_initial_visible | default: 12
%}
<section
  class="dm-proof-stats"
  style="background: {{ section.settings.background }}; color: {{ section.settings.text_color }};"
>
  <div class="dm-proof-stats__inner">
    <div class="dm-conversion-heading">
      <p class="dm-conversion-kicker">{{ section.settings.kicker }}</p>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.subtitle }}</p>
    </div>

    {% if stats_count > 0 %}
      <div class="dm-proof-stats__grid">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <article class="dm-proof-stat" {{ block.shopify_attributes }}>
              <strong>{{ block.settings.value }}</strong>
              <span>{{ block.settings.label }}</span>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.reviews_heading != blank and reviews_count > 0 %}
      <h3 class="dm-proof-stats__reviews-heading">{{ section.settings.reviews_heading | escape }}</h3>
    {% endif %}

    {% if reviews_count > 0 %}
      <div
        id="dm-proof-stats-reviews-{{ section.id }}"
        class="dm-proof-stats__reviews{% if reviews_count > reviews_initial %} dm-proof-stats__reviews--collapsible{% endif %}"
        data-initial-visible="{{ reviews_initial }}"
      >
        {% assign review_slot_index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'rating_review' %}
            {% assign review_slot_index = review_slot_index | plus: 1 %}
            <div
              class="dm-proof-stats__review-slot{% if review_slot_index > reviews_initial %} dm-proof-stats__review-slot--extra{% endif %}"
            >
              {% render 'dm-proof-rating-review', block: block %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if reviews_count > reviews_initial %}
        <div class="dm-proof-stats__read-more-row">
          <button
            type="button"
            class="dm-proof-stats__read-more"
            data-dm-proof-read-more="{{ section.id }}"
            aria-expanded="false"
            aria-controls="dm-proof-stats-reviews-{{ section.id }}"
          >
            {{- section.settings.read_more_label | escape -}}
          </button>
        </div>
      {% endif %}
    {% endif %}

    {% if section.settings.caption != blank %}
      <p class="dm-proof-stats__caption">{{ section.settings.caption }}</p>
    {% endif %}
  </div>
</section>

<style>
  .dm-proof-stats__reviews-heading {
    margin: clamp(2rem, 4vw, 2.75rem) 0 1rem;
    text-align: center;
    font-family: ui-serif, Georgia, 'Times New Roman', serif;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: #1f1715;
  }

  .dm-proof-stats__reviews {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.85rem, 2vw, 1.15rem);
    margin-top: 0.5rem;
  }

  @media screen and (min-width: 750px) {
    .dm-proof-stats__reviews {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .dm-proof-stats__reviews {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .dm-proof-stats__review-slot {
    min-width: 0;
  }

  .dm-proof-stats__reviews--collapsible:not(.is-expanded) .dm-proof-stats__review-slot--extra {
    display: none !important;
  }

  .dm-proof-stats__read-more-row {
    display: flex;
    justify-content: center;
    margin-top: clamp(1.25rem, 3vw, 1.75rem);
  }

  .dm-proof-stats__read-more {
    min-width: 10rem;
    padding: 0.65rem 1.75rem;
    border-radius: 999px;
    border: 1px solid rgba(158, 58, 102, 0.35);
    background: #fff;
    color: #9e3a66;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .dm-proof-stats__read-more:hover {
    background: rgba(207, 145, 173, 0.12);
    border-color: rgba(158, 58, 102, 0.55);
    color: #7d2e52;
  }

  .dm-proof-rating-review {
    display: flex;
    flex-direction: column;
    border: 1px solid #ecd8d2;
    border-radius: 16px;
    background: #fff;
    box-shadow: 0 10px 28px rgba(140, 55, 91, 0.06);
    overflow: hidden;
    text-align: left;
    min-height: 100%;
    box-sizing: border-box;
  }

  .dm-proof-rating-review__media {
    aspect-ratio: 4 / 3;
    background: #faf5f7;
    overflow: hidden;
  }

  .dm-proof-rating-review__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .dm-proof-rating-review__body {
    padding: clamp(1rem, 2.2vw, 1.25rem);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.65rem;
  }

  .dm-proof-rating-review__stars {
    line-height: 1;
  }

  .dm-proof-rating-review__quote {
    margin: 0;
    flex: 1;
  }

  .dm-proof-rating-review__quote p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: #332522;
  }

  .dm-proof-rating-review__footer {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding-top: 0.35rem;
    border-top: 1px solid rgba(236, 216, 210, 0.85);
    margin-top: auto;
  }

  .dm-proof-rating-review__avatar {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: linear-gradient(145deg, #f5dfe8, #cf91ad);
    color: #fff;
    font-weight: 700;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dm-proof-rating-review__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.5rem;
    font-size: 0.8125rem;
    color: #5e5450;
  }

  .dm-proof-rating-review__name {
    font-weight: 700;
    color: #1f1715;
  }

  .dm-proof-rating-review__date {
    width: 100%;
    flex-basis: 100%;
    font-size: 0.75rem;
    color: #93898e;
  }
</style>

<script>
  (function () {
    var sid = {{ section.id | json }};
    var labels = {
      more: {{ section.settings.read_more_label | default: 'Read more' | json }},
      less: {{ section.settings.read_less_label | default: 'Show less' | json }}
    };

    function bind(btn) {
      var grid = document.getElementById('dm-proof-stats-reviews-' + sid);
      if (!btn || !grid || btn.getAttribute('data-dm-proof-bound')) return;
      btn.setAttribute('data-dm-proof-bound', 'true');

      btn.addEventListener('click', function () {
        var expanded = grid.classList.toggle('is-expanded');
        btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        btn.textContent = expanded ? labels.less : labels.more;
        if (expanded) {
          grid.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    }

    function boot() {
      bind(document.querySelector('[data-dm-proof-read-more="' + sid + '"]'));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }

    document.addEventListener('shopify:section:load', function (ev) {
      if (!ev.target || !ev.target.querySelector) return;
      if (ev.target.querySelector('[data-dm-proof-read-more="' + sid + '"]')) boot();
    });
  })();
</script>

