<script>
  (function () {
    var sid = {{ section.id | json }};
    var readMoreLabels = {
      more: {{ section.settings.read_more_label | default: 'Read more' | json }},
      less: {{ section.settings.read_less_label | default: 'Show less' | json }}
    };
    var rootId = 'ProductReviews-' + sid;
    var panelId = 'dm-review-form-panel-' + sid;
    var formId = 'dm-review-contact-' + sid;

    function initDmReviewsRoot(root) {
      if (!root || root.getAttribute('data-dm-review-initialized')) return;
      root.setAttribute('data-dm-review-initialized', 'true');

      var panel = document.getElementById(panelId);
      var openBtn = root.querySelector('.js-dm-review-open');
      var form = document.getElementById(formId);

      function openPanel() {
        if (!panel) return;
        panel.removeAttribute('hidden');
        panel.classList.add('dm-review-form-wrap--open');
        if (openBtn) openBtn.setAttribute('aria-expanded', 'true');
        var focusEl =
          panel.querySelector('.dm-review-form__success') ||
          panel.querySelector('.dm-review-form__input') ||
          panel.querySelector('.js-dm-review-body');
        if (focusEl && typeof focusEl.focus === 'function') {
          try {
            focusEl.focus({ preventScroll: true });
          } catch (err) {
            focusEl.focus();
          }
        }
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      function closePanel() {
        if (!panel) return;
        panel.setAttribute('hidden', '');
        panel.classList.remove('dm-review-form-wrap--open');
        if (openBtn) openBtn.setAttribute('aria-expanded', 'false');
      }

      function panelShouldStartOpen() {
        return !!(panel && (panel.querySelector('.dm-review-form__success') || panel.querySelector('.dm-review-form__errors')));
      }

      if (panelShouldStartOpen()) openPanel();

      var uploadRoot = form ? form.querySelector('.js-dm-review-upload-root') : null;
      var fileInput = form ? form.querySelector('.js-dm-review-file') : null;
      var thumbWrap = form ? form.querySelector('.js-dm-review-thumb-wrap') : null;
      var thumbImg = form ? form.querySelector('.js-dm-review-preview-img') : null;
      var thumbActions = form ? form.querySelector('.js-dm-review-thumb-actions') : null;
      var uploadPlaceholder = form ? form.querySelector('.js-dm-review-upload-placeholder') : null;
      var previewObjectUrl = null;

      function revokeReviewPhotoPreview() {
        if (previewObjectUrl) {
          URL.revokeObjectURL(previewObjectUrl);
          previewObjectUrl = null;
        }
      }

      function clearReviewPhoto() {
        revokeReviewPhotoPreview();
        if (fileInput) fileInput.value = '';
        if (thumbImg) {
          thumbImg.removeAttribute('src');
          thumbImg.alt = '';
        }
        if (thumbWrap) thumbWrap.hidden = true;
        if (thumbActions) thumbActions.hidden = true;
        if (uploadPlaceholder) uploadPlaceholder.hidden = false;
        if (uploadRoot) uploadRoot.classList.remove('is-preview');
      }

      if (fileInput && uploadRoot && thumbWrap && thumbImg) {
        fileInput.addEventListener('change', function () {
          var file = fileInput.files && fileInput.files[0];
          if (!file) {
            clearReviewPhoto();
            return;
          }
          if (!/^image\//.test(file.type)) return;
          revokeReviewPhotoPreview();
          previewObjectUrl = URL.createObjectURL(file);
          thumbImg.src = previewObjectUrl;
          thumbImg.alt = file.name ? 'Preview: ' + file.name : 'Photo preview';
          thumbWrap.hidden = false;
          if (thumbActions) thumbActions.hidden = false;
          if (uploadPlaceholder) uploadPlaceholder.hidden = true;
          uploadRoot.classList.add('is-preview');
        });
      }

      root.addEventListener('click', function (e) {
        var t = e.target;
        if (!(t && t.closest)) return;
        if (t.closest('.js-dm-review-remove-photo')) {
          e.preventDefault();
          clearReviewPhoto();
          return;
        }
        if (t.closest('.js-dm-review-change-photo')) {
          e.preventDefault();
          if (fileInput) fileInput.click();
          return;
        }
        if (t.closest('.js-dm-review-open')) {
          e.preventDefault();
          openPanel();
          return;
        }
        if (t.closest('.js-dm-review-close')) {
          e.preventDefault();
          closePanel();
        }
      });

      document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape' || !panel || panel.hasAttribute('hidden')) return;
        if (!panel.contains(document.activeElement)) return;
        closePanel();
        if (openBtn) openBtn.focus();
      });

      var shell = root.querySelector('.js-dm-review-shell');
      var starWrap = root.querySelector('.js-dm-review-stars');
      var rating = 5;

      function syncStars(val) {
        rating = val;
        if (!starWrap) return;
        starWrap.querySelectorAll('.dm-review-form__star-btn').forEach(function (btn, idx) {
          var on = idx < val;
          btn.classList.toggle('is-active', on);
          btn.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
      }

      if (starWrap) {
        starWrap.querySelectorAll('.dm-review-form__star-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            syncStars(Number(btn.getAttribute('data-value')));
          });
        });
      }

      if (form && shell) {
        form.addEventListener('submit', function () {
          var body = form.querySelector('.js-dm-review-body');
          if (!body) return;
          var product = shell.getAttribute('data-product-title') || '';
          var prefix = 'Product: ' + product + '\nRating: ' + rating + ' / 5 stars\n\n';
          body.value = prefix + body.value.replace(/^\s+/, '');
        });
      }
    }

    function initDmProductReviewsReadMore(root) {
      var masonry = root.querySelector('.dm-product-reviews__masonry--collapsible');
      var btn = root.querySelector('[data-dm-pr-read-more="' + sid + '"]');
      if (!masonry || !btn || btn.getAttribute('data-dm-pr-bound')) return;
      btn.setAttribute('data-dm-pr-bound', 'true');
      btn.addEventListener('click', function () {
        var expanded = masonry.classList.toggle('is-expanded');
        btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        btn.textContent = expanded ? readMoreLabels.less : readMoreLabels.more;
        if (expanded) masonry.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    }

    function parseDmPrReviewDateMs(raw) {
      if (raw == null || raw === '') return 0;
      var s = String(raw).trim();
      var m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
      if (m) {
        var month = parseInt(m[1], 10) - 1;
        var day = parseInt(m[2], 10);
        var year = parseInt(m[3], 10);
        var d = new Date(year, month, day);
        var t = d.getTime();
        return isNaN(t) ? 0 : t;
      }
      var parsed = Date.parse(s);
      return isNaN(parsed) ? 0 : parsed;
    }

    function dmPrApplyCollapsibleSlotClasses(masonry, initialVisible) {
      if (!masonry || !masonry.classList.contains('dm-product-reviews__masonry--collapsible')) return;
      var cap = Math.max(0, Number(initialVisible) || 0);
      var slots = masonry.querySelectorAll('.dm-product-reviews__review-slot');
      slots.forEach(function (slot, i) {
        slot.classList.toggle('dm-product-reviews__review-slot--extra', i >= cap);
      });
    }

    function initDmProductReviewsSort(root) {
      var masonry = document.getElementById('dm-product-reviews-masonry-' + sid);
      var select = root.querySelector('[data-dm-pr-sort="' + sid + '"]');
      if (!masonry || !select || select.getAttribute('data-dm-pr-sort-bound')) return;
      select.setAttribute('data-dm-pr-sort-bound', 'true');
      var initialVisible = Number(root.getAttribute('data-dm-pr-initial-visible'));
      if (!initialVisible || initialVisible < 1) initialVisible = 12;

      function slotRating(el) {
        var n = Number(el.getAttribute('data-dm-pr-rating'));
        return isNaN(n) ? 0 : n;
      }

      function slotOrder(el) {
        var n = Number(el.getAttribute('data-dm-pr-order'));
        return isNaN(n) ? 0 : n;
      }

      function slotDateMs(el) {
        return parseDmPrReviewDateMs(el.getAttribute('data-dm-pr-date'));
      }

      function sortSlots(mode) {
        var slots = Array.prototype.slice.call(masonry.querySelectorAll('.dm-product-reviews__review-slot'));
        slots.sort(function (a, b) {
          var oa = slotOrder(a);
          var ob = slotOrder(b);
          var ra = slotRating(a);
          var rb = slotRating(b);
          var da = slotDateMs(a);
          var db = slotDateMs(b);
          if (mode === 'theme') return oa - ob;
          if (mode === 'newest') {
            if (db !== da) return db - da;
            return oa - ob;
          }
          if (mode === 'oldest') {
            if (da !== db) return da - db;
            return oa - ob;
          }
          if (mode === 'highest') {
            if (rb !== ra) return rb - ra;
            if (db !== da) return db - da;
            return oa - ob;
          }
          if (mode === 'lowest') {
            if (ra !== rb) return ra - rb;
            if (da !== db) return da - db;
            return oa - ob;
          }
          return oa - ob;
        });
        slots.forEach(function (slot) {
          masonry.appendChild(slot);
        });
        dmPrApplyCollapsibleSlotClasses(masonry, initialVisible);
      }

      select.addEventListener('change', function () {
        sortSlots(select.value || 'theme');
      });
    }

    function boot() {
      var root = document.getElementById(rootId);
      if (root) {
        initDmReviewsRoot(root);
        initDmProductReviewsSort(root);
        initDmProductReviewsReadMore(root);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }

    document.addEventListener('shopify:section:load', boot);
  })();
</script>

