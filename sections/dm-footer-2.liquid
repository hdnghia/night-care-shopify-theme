{% comment %}
  Dropmagic Section | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}


<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_mobile | default: section.settings.sectionPaddingTop_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_mobile | default: section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_mobile | default: section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_mobile | default: section.settings.sectionPaddingRight_responsive_range_desktop }}px;
    --{{ section.id }}--logoLogoSize_responsive_range: {{ section.settings.logoLogoSize_responsive_range_mobile | default: section.settings.logoLogoSize_responsive_range_desktop }}px;
    --{{ section.id }}--descriptionTextAlign_text_alignment: {{ section.settings.descriptionTextAlign_text_alignment_mobile | default: section.settings.descriptionTextAlign_text_alignment_desktop }};
    --{{ section.id }}--navMenuTextTextAlign_text_alignment: {{ section.settings.navMenuTextTextAlign_text_alignment_mobile | default: section.settings.navMenuTextTextAlign_text_alignment_desktop }};
    --{{ section.id }}--paymentBadgeBadgeWidth_responsive_range: {{ section.settings.paymentBadgeBadgeWidth_responsive_range_mobile | default: section.settings.paymentBadgeBadgeWidth_responsive_range_desktop }}px;
    --{{ section.id }}--paymentBadgeDirection_responsive_select: {{ section.settings.paymentBadgeDirection_responsive_select_mobile | default: section.settings.paymentBadgeDirection_responsive_select_desktop }};
    --{{ section.id }}--copyrightTextAlign_text_alignment: {{ section.settings.copyrightTextAlign_text_alignment_mobile | default: section.settings.copyrightTextAlign_text_alignment_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_desktop }}px;
      --{{ section.id }}--logoLogoSize_responsive_range: {{ section.settings.logoLogoSize_responsive_range_desktop }}px;
      --{{ section.id }}--descriptionTextAlign_text_alignment: {{ section.settings.descriptionTextAlign_text_alignment_desktop }};
      --{{ section.id }}--navMenuTextTextAlign_text_alignment: {{ section.settings.navMenuTextTextAlign_text_alignment_desktop }};
      --{{ section.id }}--paymentBadgeBadgeWidth_responsive_range: {{ section.settings.paymentBadgeBadgeWidth_responsive_range_desktop }}px;
      --{{ section.id }}--paymentBadgeDirection_responsive_select: {{ section.settings.paymentBadgeDirection_responsive_select_desktop }};
      --{{ section.id }}--copyrightTextAlign_text_alignment: {{ section.settings.copyrightTextAlign_text_alignment_desktop }};
    }
  }
</style>


<div class="border-t">
  <div
    data-section-combination="{{section.settings.section_combination}}"
    class="block relative w-full transition-colors bg-background "
    style="background: {{ section.settings.sectionBackground_color }}; padding-top: var(--{{ section.id }}--sectionPaddingTop_responsive_range); padding-bottom: var(--{{ section.id }}--sectionPaddingBottom_responsive_range); padding-left: var(--{{ section.id }}--sectionPaddingLeft_responsive_range); padding-right: var(--{{ section.id }}--sectionPaddingRight_responsive_range);">
    <div class="mx-auto flex flex-col gap-y-6 py-4 " style="max-width: {{ section.settings.sectionMaxWidth_number }}px;">
      <div class="flex flex-col md:flex-row items-center sm:items-start justify-between gap-y-4 md:gap-y-8">
        <div class="flex flex-col gap-y-2 md:max-w-sm">

          <a style="display:flex;" href="{% if section.settings.logoLink_link == nil %}/#{% else %}{{ section.settings.logoLink_link }}{% endif %}">
            <div class="relative" style="width: auto; display: inline-block; height: var(--{{ section.id }}--logoLogoSize_responsive_range);">
              <img
                src="{% if section.settings.logo_media == blank %}{{  settings.logo }}{% else %}{{ section.settings.logo_media | image_url }}{% endif %}"
                alt=" "
                draggable="false"
                class=""
                style="object-fit: contain; height: 100%; width: auto; background-color: transparent;">
            </div>
          </a>

          <p class="text-muted-foreground {{ section.settings.descriptionTextStyle_font_mobile }} sm:{{ section.settings.descriptionTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--descriptionTextAlign_text_alignment); color: {{ section.settings.descriptionTextColor_color }};">{{ section.settings.description_text }}</p>
        </div>
        <div class="justify-center flex flex-col items-center gap-x-8">
          <nav>


            <!-- Standard Menu (no drawer) -->
            <ul class=" items-center gap-x-8 flex-col gap-y-4 md:flex-row flex" role="list">
              {%- for link in section.settings.menu_menu.links -%}
                <li>
                  <a
                    id="{{ link.handle }}"
                    href="{{ link.url }}"
                    class="hover:underline"
                    {% if link.current %}
                    aria-current="page"
                    {% endif %}>
                    <span
                      {%- if link.current %}
                      class="underline"
                      {% endif %}>
                      <p class="text-foreground {{ section.settings.navMenuTextTextStyle_font_mobile }} sm:{{ section.settings.navMenuTextTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--navMenuTextTextAlign_text_alignment); color: {{ section.settings.navMenuTextTextColor_color }};">{{ link.title | escape }}</p>
                    </span>
                  </a>
                </li>
              {%- endfor -%}
            </ul>


          </nav>
        </div>
      </div>
      <div class="flex flex-col md:flex-row justify-between gap-y-4 border-t pt-8 gap-x-4 border-border" style="border-color: {{ section.settings.separatorColor_color }};">
        <div class="flex flex-wrap gap-2 min-h-5 w-full sm:w-fit {% if section.settings.paymentBadgeHide_checkbox %}dm-hidden{% else %}{% endif %}" style="justify-content: var(--{{ section.id }}--paymentBadgeDirection_responsive_select);">
          {%- for badge in settings.dm_payment_badge_type -%}
            <img src="{{ badge | payment_type_img_url }}" style="width: var(--{{ section.id }}--paymentBadgeBadgeWidth_responsive_range);" />
          {%- endfor -%}
        </div>
        <p class="text-foreground {{ section.settings.copyrightTextStyle_font_mobile }} sm:{{ section.settings.copyrightTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--copyrightTextAlign_text_alignment); color: {{ section.settings.copyrightTextColor_color }};">{{ section.settings.copyright_text }}</p>
      </div>


    </div>
    {{ section.settings.bottom_mask }}</div>
</div>


