{% comment %}
  Dropmagic Section | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/vanilla-infinite-marquee@1.0.12/infinite-marquee.min.css"
  defer="defer">
<script src="https://cdn.jsdelivr.net/npm/vanilla-infinite-marquee@1.0.12/infinite-marquee.bundle.js" defer="defer"></script>
<script src="{{ 'dm-marquee.js' | asset_url }}" defer="defer"></script>


<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_mobile | default: section.settings.sectionPaddingTop_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_mobile | default: section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_mobile | default: section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_mobile | default: section.settings.sectionPaddingRight_responsive_range_desktop }}px;
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_desktop }}px;
    }
  }
</style>


<div
  data-section-combination="{{section.settings.section_combination}}"
  class="relative w-full transition-colors mx-auto bg-background border border-border "
  style="background: {{ section.settings.sectionBackground_color }}; padding-top: var(--{{ section.id }}--sectionPaddingTop_responsive_range); padding-bottom: var(--{{ section.id }}--sectionPaddingBottom_responsive_range); padding-left: var(--{{ section.id }}--sectionPaddingLeft_responsive_range); padding-right: var(--{{ section.id }}--sectionPaddingRight_responsive_range); border-color: {{ section.settings.border_color }}; border-top-width: {{ section.settings.topBorder_number }}px; border-bottom-width: {{ section.settings.bottomBorder_number }}px;">
  <div class="mx-auto py-4" style="max-width: {% if section.settings.layout_select == "normal" %}{{ section.settings.sectionMaxWidth_number }}{% else %}100%{% endif %};">
    <div class="w-full !ease-linear {% if section.settings.layout_select == "normal" %}flex flex-col sm:flex-row justify-between gap-6 md:gap-14 mx-auto{% else %}{% endif %} ">
      {% if section.settings.layout_select == "carousel" %}
        <dm-marquee class="[&_.rfm-child>div]:ml-24 [&_.horizontal-marquee-inner>div]:ml-24" data-speed="{{ section.settings.marqueeSpeed_range }}">

          {%- for block in section.blocks -%}

            {%- case block.type -%}
              {%- when 'dm-text-banner-1-block-1' -%}
              {% render 'dm-text-banner-1-block-1' block: block, text_text: block.settings.text_text, textTextColor_color: block.settings.textTextColor_color, textTextStyle_font_desktop: block.settings.textTextStyle_font_desktop, textTextStyle_font_mobile: block.settings.textTextStyle_font_mobile, textTextAlign_text_alignment_desktop: block.settings.textTextAlign_text_alignment_desktop, textTextAlign_text_alignment_mobile: block.settings.textTextAlign_text_alignment_mobile, icon_icon: block.settings.icon_icon, iconIconColor_color: block.settings.iconIconColor_color, iconIconSize_responsive_range_desktop: block.settings.iconIconSize_responsive_range_desktop, iconIconSize_responsive_range_mobile: block.settings.iconIconSize_responsive_range_mobile %}{%- endcase -%}
          {%- endfor -%}
        </dm-marquee>
      {% else %}
        {%- for block in section.blocks -%}

          {%- case block.type -%}
            {%- when 'dm-text-banner-1-block-1' -%}
            {% render 'dm-text-banner-1-block-1' block: block, text_text: block.settings.text_text, textTextColor_color: block.settings.textTextColor_color, textTextStyle_font_desktop: block.settings.textTextStyle_font_desktop, textTextStyle_font_mobile: block.settings.textTextStyle_font_mobile, textTextAlign_text_alignment_desktop: block.settings.textTextAlign_text_alignment_desktop, textTextAlign_text_alignment_mobile: block.settings.textTextAlign_text_alignment_mobile, icon_icon: block.settings.icon_icon, iconIconColor_color: block.settings.iconIconColor_color, iconIconSize_responsive_range_desktop: block.settings.iconIconSize_responsive_range_desktop, iconIconSize_responsive_range_mobile: block.settings.iconIconSize_responsive_range_mobile %}{%- endcase -%}
        {%- endfor -%}
      {% endif %}
    </div>
  </div>
</div>


