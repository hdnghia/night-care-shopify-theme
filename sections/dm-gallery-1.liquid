{% comment %}
  Dropmagic Section | Version: 1.1.0
  This file is generated by Dropmagic and can be overwritten at any moment.
{% endcomment %}
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
  defer="defer" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>
<script src="{{ 'dm-swiper.js' | asset_url }}" defer="defer"></script>


<style>
  /* Mobile breakpoint - overriding the variable */
  :root {
    --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_mobile | default: section.settings.sectionPaddingTop_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_mobile | default: section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_mobile | default: section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
    --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_mobile | default: section.settings.sectionPaddingRight_responsive_range_desktop }}px;
    --{{ section.id }}--titleTextAlign_text_alignment: {{ section.settings.titleTextAlign_text_alignment_mobile | default: section.settings.titleTextAlign_text_alignment_desktop }};
    --{{ section.id }}--subtitleTextAlign_text_alignment: {{ section.settings.subtitleTextAlign_text_alignment_mobile | default: section.settings.subtitleTextAlign_text_alignment_desktop }};
    --{{ section.id }}--hideBullets_responsive_select: {{ section.settings.hideBullets_responsive_select_mobile | default: section.settings.hideBullets_responsive_select_desktop }};
    --{{ section.id }}--hideArrows_responsive_select: {{ section.settings.hideArrows_responsive_select_mobile | default: section.settings.hideArrows_responsive_select_desktop }};
  }

  /* Desktop breakpoint - overriding the variable */
  @media screen and (min-width: 768px) {
    :root {
      --{{ section.id }}--sectionPaddingTop_responsive_range: {{ section.settings.sectionPaddingTop_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingBottom_responsive_range: {{ section.settings.sectionPaddingBottom_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingLeft_responsive_range: {{ section.settings.sectionPaddingLeft_responsive_range_desktop }}px;
      --{{ section.id }}--sectionPaddingRight_responsive_range: {{ section.settings.sectionPaddingRight_responsive_range_desktop }}px;
      --{{ section.id }}--titleTextAlign_text_alignment: {{ section.settings.titleTextAlign_text_alignment_desktop }};
      --{{ section.id }}--subtitleTextAlign_text_alignment: {{ section.settings.subtitleTextAlign_text_alignment_desktop }};
      --{{ section.id }}--hideBullets_responsive_select: {{ section.settings.hideBullets_responsive_select_desktop }};
      --{{ section.id }}--hideArrows_responsive_select: {{ section.settings.hideArrows_responsive_select_desktop }};
    }
  }
</style>


<div
  data-section-combination="{{section.settings.section_combination}}"
  class="block relative w-full transition-colors bg-background "
  style="background: {{ section.settings.sectionBackground_color }}; padding-top: var(--{{ section.id }}--sectionPaddingTop_responsive_range); padding-bottom: var(--{{ section.id }}--sectionPaddingBottom_responsive_range); padding-left: var(--{{ section.id }}--sectionPaddingLeft_responsive_range); padding-right: var(--{{ section.id }}--sectionPaddingRight_responsive_range);">
  <div class="mx-auto " style="max-width: {{ section.settings.sectionMaxWidth_number }}px;">
    <div class="flex flex-col gap-6 gap-y-8 md:gap-y-10 ">
      <div class="flex flex-col gap-6 gap-y-3 ">
        <h2 class="text-foreground {{ section.settings.titleTextStyle_font_mobile }} sm:{{ section.settings.titleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--titleTextAlign_text_alignment); color: {{ section.settings.titleTextColor_color }};">{{ section.settings.title_text }}</h2>
        <p class="text-muted-foreground {{ section.settings.subtitleTextStyle_font_mobile }} sm:{{ section.settings.subtitleTextStyle_font_desktop }} dropmagic-text" style="text-align: var(--{{ section.id }}--subtitleTextAlign_text_alignment); color: {{ section.settings.subtitleTextColor_color }};">{{ section.settings.subtitle_text }}</p>
      </div>

      <div class="relative [&_.swiper-button-disabled]:!opacity-50 ">
        <div>
          <dm-swiper
            class="swiper p-1"
            {% capture swiper_config %}
            {
            "centeredSlides"
            :
            false,
            "grabCursor"
            :
            true,
            "slidesPerView"
            :
            {{ section.settings.mobileSlidesPerView_number }}
            ,
            "spaceBetween"
            :
            10,
            "breakpoints"
            :
            {"@0.75"
            :
            {"slidesPerView"
            :
            {{ section.settings.slidesPerView_number }}
            ,"spaceBetween"
            :
            20}},
            "pagination"
            :
            {"clickable"
            :true,"type"
            :"bullets"
            ,"el"
            :"#shopify-section-{{ section.id }} #dm-swiper-pagination"
            },
            "navigation"
            :
            {"nextEl"
            :"#shopify-section-{{ section.id }} #dm-swiper-navigation-right-arrow"
            ,"prevEl"
            :"#shopify-section-{{ section.id }} #dm-swiper-navigation-left-arrow"
            },
            "scrollbar"
            :
            {
            "draggable"
            :
            true
            },
            "autoplay"
            :
            {"delay"
            :
            {{ section.settings.timeBetweenSlides_number }}
            ,"disableOnInteraction"
            :
            false},
            "loop"
            :
            true
            }
            {% endcapture %}
            data-config='{{ swiper_config | strip_newlines }}'>
            <div class="swiper-wrapper">

              {%- for block in section.blocks -%}
                <div class="swiper-slide">
                  {%- case block.type -%}
                    {%- when 'dm-gallery-1-block' -%}
                    {% render 'dm-gallery-1-block' block: block, image_media: block.settings.image_media, image_media_video: block.settings.image_media_video, imageImageAspectRatio_responsive_select_desktop: block.settings.imageImageAspectRatio_responsive_select_desktop, imageImageAspectRatio_responsive_select_mobile: block.settings.imageImageAspectRatio_responsive_select_mobile, imageImageStyle_select: block.settings.imageImageStyle_select, imageImagePosition_select: block.settings.imageImagePosition_select, imageImageBorder_color: block.settings.imageImageBorder_color, imageImageBorder_number: block.settings.imageImageBorder_number, imageImageRadius_number: block.settings.imageImageRadius_number, imageImageMask_media_mask: block.settings.imageImageMask_media_mask, imageImageHide_responsive_checkbox_desktop: block.settings.imageImageHide_responsive_checkbox_desktop, imageImageHide_responsive_checkbox_mobile: block.settings.imageImageHide_responsive_checkbox_mobile %}{%- endcase -%}
                </div>
              {%- endfor -%}
            </div>
          </dm-swiper>

          <div
            id="dm-swiper-pagination"
            class="mt-3 text-center gap-x-2 flex justify-center mx-auto [&_.swiper-pagination-bullet]:!w-3 [&_.swiper-pagination-bullet]:!h-3 [&_.swiper-pagination-bullet]:aspect-square [&_.swiper-pagination-bullet-active]:!bg-primary-500 [&_.swiper-pagination-bullet-active]:outline-[1px] [&_.swiper-pagination-bullet-active]:outline [&_.swiper-pagination-bullet-active]:outline-white"
            style="display: var(--{{ section.id }}--hideBullets_responsive_select);"></div>

          <div
            id="dm-swiper-navigation-left-arrow"
            class="absolute -left-3 sm:-left-14 top-1/2 -translate-y-1/2 z-10 p-3 bg-neutral-300 rounded-full text-white"
            style="display: var(--{{ section.id }}--hideArrows_responsive_select);">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              class="w-7 h-7">
              <path
                fillRule="evenodd"
                clipRule="evenodd"
                d="M11.0607 18.5607C10.4749 19.1464 9.52513 19.1464 8.93934 18.5607L3.43934 13.0607C3.15804 12.7794 3 12.3978 3 12C3 11.6022 3.15803 11.2207 3.43934 10.9394L8.93934 5.43934C9.52512 4.85355 10.4749 4.85355 11.0607 5.43934C11.6464 6.02512 11.6464 6.97487 11.0607 7.56066L8.12131 10.5H19.5C20.3284 10.5 21 11.1716 21 12C21 12.8284 20.3284 13.5 19.5 13.5H8.12133L11.0607 16.4393C11.6464 17.0251 11.6464 17.9749 11.0607 18.5607Z"
                fill="currentColor" />
            </svg>
          </div>
          <div
            id="dm-swiper-navigation-right-arrow"
            class="absolute -right-3 sm:-right-14 top-1/2 -translate-y-1/2 z-10 p-3 bg-neutral-300 rounded-full text-white"
            style="display: var(--{{ section.id }}--hideArrows_responsive_select);">
            <svg
              class="w-7 h-7"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none">
              <path
                fillRule="evenodd"
                clipRule="evenodd"
                d="M12.9393 5.43934C13.5251 4.85355 14.4749 4.85355 15.0607 5.43934L20.5607 10.9393C20.842 11.2206 21 11.6022 21 12C21 12.3978 20.842 12.7793 20.5607 13.0606L15.0607 18.5607C14.4749 19.1464 13.5251 19.1464 12.9393 18.5607C12.3536 17.9749 12.3536 17.0251 12.9393 16.4393L15.8787 13.5H4.5C3.67157 13.5 3 12.8284 3 12C3 11.1716 3.67157 10.5 4.5 10.5H15.8787L12.9393 7.56066C12.3536 6.97488 12.3536 6.02513 12.9393 5.43934Z"
                fill="currentColor" />
            </svg>
          </div>


        </div>
      </div>
    </div>
  </div>
  {{ section.settings.bottom_mask }}</div>


