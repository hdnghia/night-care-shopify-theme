{% comment %}
  DM Gallery carousel — native horizontal scroll with snap points.
{% endcomment %}
{% liquid
  assign dm_pgc_has_slide = false
  for block in section.blocks
    if block.type == 'slide'
      assign dm_pgc_slide_src = ''
      if block.settings.image != blank
        assign dm_pgc_slide_src = block.settings.image | image_url: width: 2400
      elsif block.settings.asset_file != blank
        assign dm_af = block.settings.asset_file | strip
        if dm_af != blank
          assign dm_pgc_slide_src = dm_af | asset_url
        endif
      endif
      if dm_pgc_slide_src != blank
        assign dm_pgc_has_slide = true
      endif
    endif
  endfor
%}
<section
  class="dm-product-gallery-carousel dm-section"
  id="dm-pgc-{{ section.id }}"
  style="--dm-pgc-bg: {{ section.settings.background_color }};"
  {% unless dm_pgc_has_slide %}
    hidden
  {% endunless %}
>
  <div class="dm-pgc__inner">
    <div class="dm-pgc__stage">
      <button
        type="button"
        class="dm-pgc__nav dm-pgc__nav--prev"
        aria-label="{{ section.settings.prev_label | escape }}"
        data-dm-pgc-prev="{{ section.id }}"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M14 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="dm-pgc__viewport">
        <div class="dm-pgc__track" data-dm-pgc-track="{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'slide' -%}
              {%- liquid
                assign dm_u = ''
                if block.settings.image != blank
                  assign dm_u = block.settings.image | image_url: width: 1400
                elsif block.settings.asset_file != blank
                  assign dm_af2 = block.settings.asset_file | strip
                  if dm_af2 != blank
                    assign dm_u = dm_af2 | asset_url
                  endif
                endif
              -%}
              {%- if dm_u != blank -%}
                <div class="dm-pgc__slide" {{ block.shopify_attributes }}>
                  <img
                    src="{{ dm_u }}"
                    alt="{{ block.settings.alt | default: '' | escape }}"
                    width="700"
                    height="620"
                    loading="lazy"
                    decoding="async"
                  >
                </div>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <button
        type="button"
        class="dm-pgc__nav dm-pgc__nav--next"
        aria-label="{{ section.settings.next_label | escape }}"
        data-dm-pgc-next="{{ section.id }}"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M10 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

</section>

<style>
  .dm-product-gallery-carousel {
    width: 100%;
    margin: 0;
    padding: clamp(1.75rem, 4vw, 3rem) max(1rem, env(safe-area-inset-left, 0px))
      clamp(1.75rem, 4vw, 3rem) max(1rem, env(safe-area-inset-right, 0px));
    box-sizing: border-box;
    background: var(--dm-pgc-bg, #fdf8fa);
  }

  .dm-pgc__inner {
    max-width: 86rem;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .dm-pgc__stage {
    --dm-pgc-gap: clamp(0.85rem, 1.45vw, 1.25rem);
    position: relative;
    display: grid;
    grid-template-columns: 1.75rem minmax(0, 1fr) 1.75rem;
    align-items: center;
    gap: clamp(0.55rem, 1vw, 0.85rem);
  }

  .dm-pgc__viewport {
    min-width: 0;
    overflow: hidden;
  }

  .dm-pgc__track {
    display: flex;
    gap: var(--dm-pgc-gap);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-padding-inline: 0;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .dm-pgc__track::-webkit-scrollbar {
    display: none;
  }

  .dm-pgc__slide {
    flex: 0 0 calc((100% - (var(--dm-pgc-gap) * 4)) / 5);
    aspect-ratio: 1.08 / 1;
    border: 1px solid rgba(31, 23, 21, 0.08);
    border-radius: 18px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.72);
    scroll-snap-align: start;
    min-width: 0;
    box-shadow: 0 10px 26px rgba(140, 55, 91, 0.06);
  }

  .dm-pgc__slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dm-pgc__nav {
    width: 1.75rem;
    height: 2rem;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: transparent;
    color: #b8bac0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, background 0.15s ease, opacity 0.15s ease;
    align-self: center;
  }

  .dm-pgc__nav:hover {
    background: transparent;
    color: #8f9298;
  }

  .dm-pgc__nav[disabled] {
    opacity: 0.35;
    cursor: default;
  }

  .dm-pgc__nav[disabled]:hover {
    background: transparent;
    color: #b8bac0;
  }

  .dm-pgc__nav:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(143, 146, 152, 0.24);
  }

  @media screen and (max-width: 749px) {
    .dm-pgc__stage {
      --dm-pgc-gap: 0.8rem;
      grid-template-columns: 1.5rem minmax(0, 1fr) 1.5rem;
      gap: 0.35rem;
    }

    .dm-pgc__track {
      scroll-padding-inline: 0.15rem;
    }

    .dm-pgc__slide {
      flex-basis: min(78vw, 18rem);
    }

    .dm-pgc__nav {
      width: 1.5rem;
      height: 1.5rem;
    }
  }

  @media screen and (min-width: 750px) {
    .dm-pgc__slide {
      flex: 0 0 calc((100% - (var(--dm-pgc-gap) * 4)) / 5) !important;
      max-width: calc((100% - (var(--dm-pgc-gap) * 4)) / 5);
    }
  }
</style>

<script>
  (function () {
    var rootId = 'dm-pgc-{{ section.id }}';
    var sid = {{ section.id | json }};

    function initDmGalleryCarousel(root) {
      if (!root || root.getAttribute('data-dm-pgc-init')) return;
      var track = root.querySelector('[data-dm-pgc-track="' + sid + '"]');
      var slides = track ? track.querySelectorAll('.dm-pgc__slide') : [];
      if (!track || !slides.length) return;
      root.removeAttribute('hidden');
      root.setAttribute('data-dm-pgc-init', 'true');

      var prev = root.querySelector('[data-dm-pgc-prev="' + sid + '"]');
      var next = root.querySelector('[data-dm-pgc-next="' + sid + '"]');

      function stepSize() {
        var firstSlide = track.querySelector('.dm-pgc__slide');
        if (!firstSlide) return track.clientWidth;
        var styles = window.getComputedStyle(track);
        var gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
        return firstSlide.getBoundingClientRect().width + gap;
      }

      function updateButtons() {
        var maxScroll = Math.max(0, track.scrollWidth - track.clientWidth - 1);
        if (prev) prev.disabled = track.scrollLeft <= 1;
        if (next) next.disabled = track.scrollLeft >= maxScroll;
      }

      function go(delta) {
        track.scrollBy({ left: stepSize() * delta, behavior: 'smooth' });
      }

      root.addEventListener('click', function (e) {
        var t = e.target;
        if (!(t && t.closest)) return;
        if (t.closest('[data-dm-pgc-prev="' + sid + '"]')) {
          e.preventDefault();
          go(-1);
        } else if (t.closest('[data-dm-pgc-next="' + sid + '"]')) {
          e.preventDefault();
          go(1);
        }
      });

      var resizeTimer;
      track.addEventListener('scroll', function () {
        window.requestAnimationFrame(updateButtons);
      });

      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          updateButtons();
        }, 120);
      });

      updateButtons();
    }

    function boot() {
      var root = document.getElementById(rootId);
      if (root) initDmGalleryCarousel(root);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }

    document.addEventListener('shopify:section:load', function (ev) {
      if (!ev.detail || String(ev.detail.sectionId) !== String(sid)) return;
      var root = document.getElementById(rootId);
      if (root) root.removeAttribute('data-dm-pgc-init');
      boot();
    });
  })();
</script>

{% schema %}
{
  "name": "DM Gallery carousel",
  "tag": "section",
  "class": "dm-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fdf8fa"
    },
    {
      "type": "text",
      "id": "prev_label",
      "label": "Previous button label",
      "default": "Previous images"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "Next button label",
      "default": "Next images"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Optional. If empty, the theme asset filename below is used."
        },
        {
          "type": "text",
          "id": "asset_file",
          "label": "Asset filename (fallback)",
          "default": "hana-freepik_assistant_1774975623581.png",
          "info": "File from the Assets folder (e.g. photo.png)."
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Image alt text",
          "default": "HANA Collagen Night Wrapping Mask product image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DM Gallery carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "asset_file": "hana-freepik_assistant_1774975623581.png",
            "alt": "HANA Collagen Night Wrapping Mask product image"
          }
        },
        {
          "type": "slide",
          "settings": {
            "asset_file": "hana-freepik_assistant_1774975624483.png",
            "alt": "HANA Collagen Night Wrapping Mask with hydration effect"
          }
        },
        {
          "type": "slide",
          "settings": {
            "asset_file": "hana-freepik_assistant_1774975626707.png",
            "alt": "HANA Collagen Night Wrapping Mask skincare product close-up"
          }
        },
        {
          "type": "slide",
          "settings": {
            "asset_file": "hana-freepik_assistant_1774975760806_f73937bd-506e-49d6-a30e-596789aa2e4e.png",
            "alt": "HANA Collagen Night Wrapping Mask beauty product"
          }
        }
      ]
    }
  ]
}
{% endschema %}
